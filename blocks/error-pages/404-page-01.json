{
  "root": "not-found-page",
  "elements": {
    "not-found-page": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "align": "center",
        "justify": "center",
        "gap": 4,
        "container": true
      },
      "children": [
        "illustration-area",
        "error-code",
        "error-heading",
        "error-description",
        "search-section",
        "nav-buttons",
        "help-links"
      ]
    },
    "illustration-area": {
      "type": "Image",
      "props": {
        "src": "https://picsum.photos/seed/lost404/400/250",
        "alt": "Lost in space illustration"
      }
    },
    "error-code": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "404",
        "weight": "bold",
        "align": "center",
        "variant": "muted"
      }
    },
    "error-heading": {
      "type": "Text",
      "props": {
        "tag": "h1",
        "content": "Page not found",
        "weight": "bold",
        "align": "center"
      }
    },
    "error-description": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Sorry, the page you're looking for doesn't exist or has been moved. Try searching for what you need or head back to the homepage.",
        "variant": "muted",
        "align": "center"
      }
    },
    "search-section": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "search-input",
        "search-button"
      ]
    },
    "search-input": {
      "type": "Search",
      "props": {
        "placeholder": "Search for pages, articles, products..."
      }
    },
    "search-button": {
      "type": "Button",
      "props": {
        "label": "Search",
        "variant": "primary",
        "icon": "search"
      }
    },
    "nav-buttons": {
      "type": "ButtonGroup",
      "children": [
        "home-button",
        "back-button"
      ]
    },
    "home-button": {
      "type": "Button",
      "props": {
        "label": "Go to Homepage",
        "variant": "primary",
        "icon": "home"
      }
    },
    "back-button": {
      "type": "Button",
      "props": {
        "label": "Go Back",
        "variant": "outline",
        "icon": "arrow-left"
      }
    },
    "help-links": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3,
        "align": "center"
      },
      "children": [
        "help-label",
        "link-docs",
        "link-support",
        "link-status"
      ]
    },
    "help-label": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Helpful links:",
        "variant": "muted"
      }
    },
    "link-docs": {
      "type": "Link",
      "props": {
        "label": "Documentation"
      }
    },
    "link-support": {
      "type": "Link",
      "props": {
        "label": "Contact Support"
      }
    },
    "link-status": {
      "type": "Link",
      "props": {
        "label": "System Status"
      }
    }
  }
}
