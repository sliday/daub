{
  "root": "not-found-simple-01",
  "elements": {
    "not-found-simple-01": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "align": "start",
        "justify": "center",
        "container": "narrow",
        "gap": 6
      },
      "children": [
        "heading-group",
        "actions"
      ]
    },
    "heading-group": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3
      },
      "children": [
        "error-label",
        "heading",
        "description"
      ]
    },
    "error-label": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "404 error",
        "variant": "brand"
      }
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h1",
        "content": "We can't find that page"
      }
    },
    "description": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Sorry, the page you are looking for doesn't exist or has been moved.",
        "variant": "secondary"
      }
    },
    "actions": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3
      },
      "children": [
        "back-btn",
        "home-btn"
      ]
    },
    "back-btn": {
      "type": "Button",
      "props": {
        "label": "Go back",
        "variant": "outline",
        "size": "lg",
        "icon": "arrow-left"
      }
    },
    "home-btn": {
      "type": "Button",
      "props": {
        "label": "Take me home",
        "variant": "primary",
        "size": "lg"
      }
    }
  }
}
