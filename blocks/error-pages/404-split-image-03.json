{
  "root": "not-found-split-03",
  "elements": {
    "not-found-split-03": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "align": "center",
        "justify": "center",
        "gap": 6,
        "container": true,
        "padding": [8, 0]
      },
      "children": [
        "text-section",
        "image-section"
      ]
    },

    "text-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6
      },
      "children": [
        "heading-group",
        "actions"
      ]
    },
    "heading-group": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3
      },
      "children": [
        "error-label",
        "heading",
        "description"
      ]
    },
    "error-label": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "404 error",
        "variant": "brand"
      }
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h1",
        "content": "Page not found"
      }
    },
    "description": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Sorry, the page you are looking for doesn't exist. Here are some helpful links:",
        "variant": "secondary"
      }
    },
    "actions": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3
      },
      "children": [
        "back-btn",
        "home-btn"
      ]
    },
    "back-btn": {
      "type": "Button",
      "props": {
        "label": "Go back",
        "variant": "outline",
        "size": "lg",
        "icon": "arrow-left"
      }
    },
    "home-btn": {
      "type": "Button",
      "props": {
        "label": "Take me home",
        "variant": "primary",
        "size": "lg"
      }
    },

    "image-section": {
      "type": "Image",
      "props": {
        "src": "data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22592%22%20height%3D%22640%22%20viewBox%3D%220%200%20592%20640%22%3E%3Crect%20width%3D%22592%22%20height%3D%22640%22%20rx%3D%2216%22%20fill%3D%22%23F2F4F7%22%2F%3E%3Ccircle%20cx%3D%22296%22%20cy%3D%22280%22%20r%3D%22160%22%20fill%3D%22%23E4E7EC%22%20opacity%3D%220.5%22%2F%3E%3Ccircle%20cx%3D%22296%22%20cy%3D%22280%22%20r%3D%22100%22%20fill%3D%22%23D0D5DD%22%20opacity%3D%220.4%22%2F%3E%3Ccircle%20cx%3D%22296%22%20cy%3D%22280%22%20r%3D%2250%22%20fill%3D%22%237F56D920%22%2F%3E%3Crect%20x%3D%22150%22%20y%3D%22460%22%20width%3D%22292%22%20height%3D%2216%22%20rx%3D%228%22%20fill%3D%22%23E4E7EC%22%2F%3E%3Crect%20x%3D%22200%22%20y%3D%22490%22%20width%3D%22192%22%20height%3D%2212%22%20rx%3D%226%22%20fill%3D%22%23E4E7EC%22%2F%3E%3C%2Fsvg%3E",
        "alt": "Abstract placeholder",
        "rounded": true
      }
    }
  }
}
