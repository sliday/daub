{
  "root": "not-found-maintenance",
  "elements": {
    "not-found-maintenance": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "align": "center",
        "justify": "center",
        "gap": 6,
        "container": true,
        "padding": [8, 0]
      },
      "children": [
        "text-section",
        "mockup-section"
      ]
    },

    "text-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6
      },
      "children": [
        "heading-group",
        "actions"
      ]
    },
    "heading-group": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3
      },
      "children": [
        "error-label",
        "heading",
        "description"
      ]
    },
    "error-label": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "404 error",
        "variant": "brand"
      }
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h1",
        "content": "Under maintenance"
      }
    },
    "description": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "The page you're looking for is currently under maintenance and will be back soon. Stay tuned!",
        "variant": "secondary"
      }
    },
    "actions": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3
      },
      "children": [
        "back-btn",
        "home-btn"
      ]
    },
    "back-btn": {
      "type": "Button",
      "props": {
        "label": "Go back",
        "variant": "outline",
        "size": "lg",
        "icon": "arrow-left"
      }
    },
    "home-btn": {
      "type": "Button",
      "props": {
        "label": "Take me home",
        "variant": "primary",
        "size": "lg"
      }
    },

    "mockup-section": {
