{
  "root": "not-found-split-01",
  "elements": {
    "not-found-split-01": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 0
      },
      "children": [
        "text-panel",
        "image-panel"
      ]
    },

    "text-panel": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "justify": "end",
        "padding": [8, 6],
        "gap": 6
      },
      "children": [
        "heading-group",
        "actions"
      ]
    },
    "heading-group": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3
      },
      "children": [
        "heading",
        "description"
      ]
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h1",
        "content": "Page not found"
      }
    },
    "description": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Sorry, the page you are looking for doesn't exist or has been moved. Here are some helpful links:",
        "variant": "secondary"
      }
    },
    "actions": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3
      },
      "children": [
        "back-btn",
        "home-btn"
      ]
    },
    "back-btn": {
      "type": "Button",
      "props": {
        "label": "Go back",
        "variant": "outline",
        "size": "lg",
        "icon": "arrow-left"
      }
    },
    "home-btn": {
      "type": "Button",
      "props": {
        "label": "Take me home",
        "variant": "primary",
        "size": "lg"
      }
    },

    "image-panel": {
      "type": "Image",
      "props": {
        "src": "data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22720%22%20height%3D%22960%22%20viewBox%3D%220%200%20720%20960%22%3E%3ClinearGradient%20id%3D%22g%22%20x1%3D%220%22%20y1%3D%220%22%20x2%3D%221%22%20y2%3D%221%22%3E%3Cstop%20offset%3D%220%22%20stop-color%3D%22%237F56D9%22%2F%3E%3Cstop%20offset%3D%221%22%20stop-color%3D%22%239E77ED%22%2F%3E%3C%2FlinearGradient%3E%3Crect%20width%3D%22720%22%20height%3D%22960%22%20fill%3D%22url(%23g)%22%2F%3E%3Ccircle%20cx%3D%22200%22%20cy%3D%22300%22%20r%3D%22180%22%20fill%3D%22%23ffffff10%22%2F%3E%3Ccircle%20cx%3D%22500%22%20cy%3D%22600%22%20r%3D%22220%22%20fill%3D%22%23ffffff10%22%2F%3E%3Ccircle%20cx%3D%22360%22%20cy%3D%22480%22%20r%3D%22120%22%20fill%3D%22%23ffffff08%22%2F%3E%3Ccircle%20cx%3D%22150%22%20cy%3D%22700%22%20r%3D%2280%22%20fill%3D%22%23ffffff0C%22%2F%3E%3Ccircle%20cx%3D%22600%22%20cy%3D%22200%22%20r%3D%22100%22%20fill%3D%22%23ffffff0C%22%2F%3E%3C%2Fsvg%3E",
        "alt": "Abstract purple gradient",
        "objectFit": "cover",
        "fullHeight": true
      }
    }
  }
}
