{
  "root": "not-found-split-04",
  "elements": {
    "not-found-split-04": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "align": "center",
        "justify": "center",
        "gap": 6,
        "container": true,
        "padding": [8, 0]
      },
      "children": [
        "text-section",
        "image-section"
      ]
    },

    "text-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6
      },
      "children": [
        "heading-group",
        "search-row",
        "resources"
      ]
    },
    "heading-group": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3
      },
      "children": [
        "error-label",
        "heading",
        "description"
      ]
    },
    "error-label": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "404 error",
        "variant": "brand"
      }
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h1",
        "content": "We lost this page"
      }
    },
    "description": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Sorry, the page you are looking for doesn't exist.",
        "variant": "secondary"
      }
    },
    "search-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3
      },
      "children": [
        "search-input",
        "search-btn"
      ]
    },
    "search-input": {
      "type": "Search",
      "props": {
        "placeholder": "Search our site"
      }
    },
    "search-btn": {
      "type": "Button",
      "props": {
        "label": "Search",
        "variant": "primary"
      }
    },
    "resources": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "resource-docs",
        "resource-blog",
        "resource-support"
      ]
    },
    "resource-docs": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "docs-link",
        "docs-text"
      ]
    },
    "docs-link": {
      "type": "Link",
      "props": {
        "label": "Documentation"
      }
    },
    "docs-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Dive in to learn all about our product.",
        "variant": "secondary"
      }
    },
    "resource-blog": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "blog-link",
        "blog-text"
      ]
    },
    "blog-link": {
      "type": "Link",
      "props": {
        "label": "Our blog"
      }
    },
    "blog-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Read the latest posts on our blog.",
        "variant": "secondary"
      }
    },
    "resource-support": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "support-link",
        "support-text"
      ]
    },
    "support-link": {
      "type": "Link",
      "props": {
        "label": "Chat to support"
      }
    },
    "support-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Our friendly team is here to help.",
        "variant": "secondary"
      }
    },

    "image-section": {
      "type": "Image",
      "props": {
        "src": "data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22592%22%20height%3D%22640%22%20viewBox%3D%220%200%20592%20640%22%3E%3Crect%20width%3D%22592%22%20height%3D%22640%22%20rx%3D%2216%22%20fill%3D%22%23F9FAFB%22%2F%3E%3Crect%20x%3D%2240%22%20y%3D%2240%22%20width%3D%22512%22%20height%3D%22280%22%20rx%3D%2212%22%20fill%3D%22%23F2F4F7%22%20stroke%3D%22%23E4E7EC%22%20stroke-width%3D%221%22%2F%3E%3Crect%20x%3D%2270%22%20y%3D%2270%22%20width%3D%22180%22%20height%3D%2214%22%20rx%3D%224%22%20fill%3D%22%23E4E7EC%22%2F%3E%3Crect%20x%3D%2270%22%20y%3D%22100%22%20width%3D%22452%22%20height%3D%22180%22%20rx%3D%228%22%20fill%3D%22white%22%20stroke%3D%22%23E4E7EC%22%20stroke-width%3D%221%22%2F%3E%3Cpath%20d%3D%22M90%20260%20C130%20220%2C170%20200%2C210%20180%20C250%20160%2C290%20190%2C330%20170%20C370%20150%2C410%20140%2C450%20160%20C490%20180%2C500%20150%2C502%20155%22%20fill%3D%22none%22%20stroke%3D%22%237F56D9%22%20stroke-width%3D%222.5%22%20stroke-linecap%3D%22round%22%2F%3E%3Crect%20x%3D%2240%22%20y%3D%22350%22%20width%3D%22248%22%20height%3D%22120%22%20rx%3D%2212%22%20fill%3D%22%23F2F4F7%22%20stroke%3D%22%23E4E7EC%22%20stroke-width%3D%221%22%2F%3E%3Crect%20x%3D%2260%22%20y%3D%22375%22%20width%3D%22100%22%20height%3D%2212%22%20rx%3D%224%22%20fill%3D%22%23E4E7EC%22%2F%3E%3Crect%20x%3D%2260%22%20y%3D%22400%22%20width%3D%22160%22%20height%3D%2220%22%20rx%3D%224%22%20fill%3D%22%237F56D920%22%2F%3E%3Crect%20x%3D%22304%22%20y%3D%22350%22%20width%3D%22248%22%20height%3D%22120%22%20rx%3D%2212%22%20fill%3D%22%23F2F4F7%22%20stroke%3D%22%23E4E7EC%22%20stroke-width%3D%221%22%2F%3E%3Crect%20x%3D%22324%22%20y%3D%22375%22%20width%3D%22100%22%20height%3D%2212%22%20rx%3D%224%22%20fill%3D%22%23E4E7EC%22%2F%3E%3Crect%20x%3D%22324%22%20y%3D%22400%22%20width%3D%22160%22%20height%3D%2220%22%20rx%3D%224%22%20fill%3D%22%237F56D920%22%2F%3E%3C%2Fsvg%3E",
        "alt": "Dashboard placeholder",
        "rounded": true
      }
    }
  }
}
