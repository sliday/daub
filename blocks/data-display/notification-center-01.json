{
  "root": "notification-center",
  "elements": {
    "notification-center": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 4 },
      "children": ["notif-header", "notif-list"]
    },
    "notif-header": {
      "type": "Stack",
      "props": { "direction": "horizontal", "gap": 0, "justify": "between", "align": "center" },
      "children": ["notif-title", "mark-read-btn"]
    },
    "notif-title": {
      "type": "Text",
      "props": { "tag": "h3", "content": "Notifications" }
    },
    "mark-read-btn": {
      "type": "Button",
      "props": { "label": "Mark all read", "variant": "ghost", "size": "sm" }
    },
    "notif-list": {
      "type": "List",
      "props": {
        "items": [
          { "title": "Sarah Chen commented on your design", "secondary": "2 minutes ago", "icon": "message-circle" },
          { "title": "Your export \"Q4 Report\" is ready", "secondary": "15 minutes ago", "icon": "download" },
          { "title": "New team member joined: Alex Rivera", "secondary": "1 hour ago", "icon": "user-plus" },
          { "title": "Build #1247 deployed successfully", "secondary": "3 hours ago", "icon": "check-circle" },
          { "title": "Storage usage at 85% capacity", "secondary": "Yesterday", "icon": "alert-triangle" },
          { "title": "Weekly analytics summary available", "secondary": "2 days ago", "icon": "bar-chart" }
        ]
      }
    }
  }
}