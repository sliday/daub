    "integration-grid": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "container": true
      },
      "children": [
        "integrations-header",
        "integrations-grid",
        "integrations-cta"
      ]
    },
    "integrations-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1,
        "align": "center"
      },
      "children": [
        "integrations-title",
        "integrations-subtitle"
      ]
    },
    "integrations-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Works With Your Stack",
        "weight": "bold",
        "align": "center"
      }
    },
    "integrations-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Connect to the tools you already use. Set up in minutes, not days.",
        "variant": "muted",
        "align": "center"
      }
    },
    "integrations-grid": {
      "type": "Grid",
      "props": {
        "columns": 4,
        "gap": 3
      },
      "children": [
        "int-slack",
        "int-github",
        "int-jira",
        "int-figma",
        "int-notion",
        "int-stripe",
        "int-zapier",
