{
  "root": "newsletter-popup",
  "elements": {
    "newsletter-popup": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0,
        "align": "center",
        "justify": "center",
        "container": "narrow"
      },
      "children": [
        "nl-popup-card"
      ]
    },
    "nl-popup-card": {
      "type": "Card",
      "props": {},
      "children": [
        "nl-popup-body"
      ]
    },
    "nl-popup-body": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "align": "center"
      },
      "children": [
        "nl-popup-icon",
        "nl-popup-heading",
        "nl-popup-desc",
        "nl-popup-form",
        "nl-popup-footer"
      ]
    },
    "nl-popup-icon": {
      "type": "Icon",
      "props": {
        "name": "mail",
        "size": "lg"
      }
    },
    "nl-popup-heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Get 20% off your first order",
        "weight": "bold",
        "align": "center"
      }
    },
    "nl-popup-desc": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Subscribe to our newsletter and receive an exclusive discount code, plus early access to new releases and member-only deals.",
        "variant": "muted",
        "align": "center"
      }
    },
    "nl-popup-form": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "nl-popup-email",
        "nl-popup-submit"
      ]
    },
    "nl-popup-email": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email address"
      }
    },
    "nl-popup-submit": {
      "type": "Button",
      "props": {
        "label": "Claim My Discount",
        "variant": "primary",
        "size": "lg"
      }
    },
    "nl-popup-footer": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Your information is secure. Unsubscribe at any time.",
        "variant": "muted"
      }
    }
  }
}
