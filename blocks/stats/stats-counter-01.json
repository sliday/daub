{
  "root": "stats-counter",
  "elements": {
    "stats-counter": {
      "type": "Surface",
      "props": {
        "variant": "flat"
      },
      "children": [
        "sc-inner"
      ]
    },
    "sc-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "container": true,
        "align": "center"
      },
      "children": [
        "sc-header",
        "sc-sub",
        "sc-numbers"
      ]
    },
    "sc-header": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Trusted by Teams Worldwide",
        "weight": "bold",
        "align": "center"
      }
    },
    "sc-sub": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Numbers that speak for themselves.",
        "variant": "muted",
        "align": "center"
      }
    },
    "sc-numbers": {
      "type": "Grid",
      "props": {
        "columns": 4,
        "gap": 4
      },
      "children": [
        "sc-num-1",
        "sc-num-2",
        "sc-num-3",
        "sc-num-4"
      ]
    },
    "sc-num-1": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1,
        "align": "center"
      },
      "children": [
        "sc-val-1",
        "sc-lbl-1"
      ]
    },
    "sc-val-1": {
      "type": "Text",
      "props": {
        "tag": "h1",
        "content": "500K+",
        "weight": "bold"
