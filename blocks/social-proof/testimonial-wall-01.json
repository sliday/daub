      "columns": 3,
      "gap": 3,
      "children": ["tile-1", "tile-2", "tile-3", "tile-4", "tile-5", "tile-6"]
    },
    "tile-1": {
      "type": "Surface",
      "variant": "bordered",
      "children": ["tile-1-inner"]
    },
    "tile-1-inner": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 3,
      "children": ["tile-1-author", "tile-1-text"]
    },
    "tile-1-author": {
      "type": "Stack",
      "direction": "horizontal",
      "gap": 2,
      "align": "center",
      "children": ["tile-1-avatar", "tile-1-name"]
    },
    "tile-1-avatar": {
      "type": "Avatar",
      "initials": "EH",
      "size": "sm",
      "src": "https://i.pravatar.cc/64?u=emily-huang"
    },
    "tile-1-name": {
      "type": "Text",
      "tag": "p",
      "content": "Emily Huang",
      "weight": "semibold"
    },
    "tile-1-text": {
      "type": "Text",
      "tag": "p",
      "content": "Deployed to production in under 10 minutes on my first try. No other platform comes close."
    },
