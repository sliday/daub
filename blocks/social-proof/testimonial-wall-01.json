{
  "root": "testimonial-wall",
  "elements": {
    "testimonial-wall": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 5,
      "container": "wide",
      "children": ["wall-header", "wall-grid"]
    },
    "wall-header": {
      "type": "Text",
      "tag": "h2",
      "content": "Loved by thousands of teams",
      "align": "center"
    },
    "wall-grid": {
