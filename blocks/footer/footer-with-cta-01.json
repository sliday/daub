{
  "root": "footer-with-cta",
  "elements": {
    "footer-with-cta": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 5,
        "container": "wide"
      },
      "children": [
        "cta-banner",
        "footer-divider",
        "link-columns",
        "bottom-divider",
        "bottom-row"
      ]
    },
    "cta-banner": {
      "type": "Surface",
      "props": {
        "variant": "raised"
      },
      "children": [
        "cta-content"
      ]
    },
    "cta-content": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 4,
        "align": "center",
        "justify": "between"
      },
      "children": [
        "cta-text-group",
        "cta-actions"
      ]
    },
    "cta-text-group": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "cta-heading",
        "cta-description"
      ]
    },
    "cta-heading": {
      "type": "Text",
      "props": {
        "tag": "h3",
        "content": "Ready to get started?",
        "weight": "bold"
      }
    },
    "cta-description": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Join 10,000+ teams already using Acme Studio to ship faster.",
        "variant": "muted"
      }
    },
    "cta-actions": {
      "type": "ButtonGroup",
      "children": [
        "cta-primary",
        "cta-secondary"
      ]
    },
    "cta-primary": {
      "type": "Button",
      "props": {
        "label": "Start Free Trial",
        "variant": "primary"
      }
    },
    "cta-secondary": {
      "type": "Button",
      "props": {
        "label": "Talk to Sales",
        "variant": "outline"
      }
    },
    "footer-divider": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "link-columns": {
      "type": "Grid",
      "props": {
        "columns": 4,
        "gap": 5
      },
      "children": [
        "col-product",
        "col-company",
        "col-resources",
        "col-connect"
      ]
    },
    "col-product": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3
      },
      "children": [
        "product-label",
        "product-links"
      ]
    },
    "product-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Product",
        "weight": "semibold"
      }
    },
    "product-links": {
      "type": "NavMenu",
      "props": {
        "direction": "vertical",
        "items": [
          {
            "label": "Features",
            "href": "/features"
          },
          {
            "label": "Pricing",
            "href": "/pricing"
          },
          {
            "label": "Security",
            "href": "/security"
          }
        ]
      }
    },
    "col-company": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3
      },
      "children": [
        "company-label",
        "company-links"
      ]
    },
    "company-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Company",
        "weight": "semibold"
      }
    },
    "company-links": {
      "type": "NavMenu",
      "props": {
        "direction": "vertical",
        "items": [
          {
            "label": "About",
            "href": "/about"
          },
          {
            "label": "Blog",
            "href": "/blog"
          },
          {
            "label": "Careers",
            "href": "/careers"
          }
        ]
      }
    },
    "col-resources": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3
      },
      "children": [
        "resources-label",
        "resources-links"
      ]
    },
    "resources-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Resources",
        "weight": "semibold"
      }
    },
    "resources-links": {
      "type": "NavMenu",
      "props": {
        "direction": "vertical",
        "items": [
          {
            "label": "Docs",
            "href": "/docs"
          },
          {
            "label": "Help Center",
            "href": "/help"
          },
          {
            "label": "Guides",
            "href": "/guides"
          }
        ]
      }
    },
    "col-connect": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3
      },
      "children": [
        "connect-label",
        "social-buttons"
      ]
    },
    "connect-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Connect",
        "weight": "semibold"
      }
    },
    "social-buttons": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "social-x",
        "social-github",
        "social-linkedin"
      ]
    },
    "social-x": {
      "type": "Button",
      "props": {
        "label": "Twitter",
        "icon": "twitter",
        "variant": "ghost",
        "size": "sm"
      }
    },
    "social-github": {
      "type": "Button",
      "props": {
        "label": "GitHub",
        "icon": "github",
        "variant": "ghost",
        "size": "sm"
      }
    },
    "social-linkedin": {
      "type": "Button",
      "props": {
        "label": "LinkedIn",
        "icon": "linkedin",
        "variant": "ghost",
        "size": "sm"
      }
    },
    "bottom-divider": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "bottom-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 4,
        "align": "center",
        "justify": "between"
      },
      "children": [
        "copyright",
        "legal-links"
      ]
    },
    "copyright": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "© 2026 Acme Studio, Inc. All rights reserved.",
        "variant": "muted"
      }
    },
    "legal-links": {
      "type": "NavMenu",
      "props": {
        "direction": "horizontal",
        "items": [
          {
            "label": "Privacy",
            "href": "/privacy"
          },
          {
            "label": "Terms",
            "href": "/terms"
          },
          {
            "label": "Cookies",
            "href": "/cookies"
          }
        ]
      }
    }
  }
}
