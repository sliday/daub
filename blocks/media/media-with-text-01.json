{
  "root": "media-with-text",
  "elements": {
    "media-with-text": {
      "type": "Grid",
      "columns": 2,
      "gap": 4,
      "container": true,
      "children": ["media-image-block", "media-text-block"]
    },
    "media-image-block": {
      "type": "Surface",
      "variant": "bordered",
      "children": ["media-image-aspect"]
    },
    "media-image-aspect": {
      "type": "AspectRatio",
      "ratio": "4/3",
      "children": ["media-image"]
    },
    "media-image": {
      "type": "Image",
      "src": "https://picsum.photos/seed/media-team/640/480",
      "alt": "Engineering team collaborating around a large monitor"
    },
    "media-text-block": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 3,
      "justify": "center",
      "children": ["media-badge", "media-heading", "media-description", "media-stats-row", "media-actions"]
    },
    "media-badge": {
      "type": "Badge",
      "text": "About Us",
      "variant": "secondary"
    },
    "media-heading": {
      "type": "Text",
      "tag": "h2",
      "content": "Built by Engineers, for Engineers",
      "weight": "bold"
    },
    "media-description": {
      "type": "Text",
      "tag": "p",
      "content": "Our founding team spent a decade building developer tools at companies like GitHub, Stripe, and Vercel. We understand the pain of fragmented workflows because we lived it. That frustration became the catalyst for building a platform that puts developer experience first.",
      "variant": "muted"
    },
    "media-stats-row": {
      "type": "Stack",
      "direction": "horizontal",
      "gap": 4,
      "children": ["media-stat-1", "media-stat-sep", "media-stat-2", "media-stat-sep-2", "media-stat-3"]
    },
    "media-stat-1": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 0,
      "children": ["media-stat-1-value", "media-stat-1-label"]
    },
    "media-stat-1-value": {
      "type": "Text",
      "tag": "span",
      "content": "85",
      "weight": "bold"
    },
    "media-stat-1-label": {
      "type": "Text",
      "tag": "span",
      "content": "Team members",
      "variant": "muted"
    },
    "media-stat-sep": {
      "type": "Separator",
      "orientation": "vertical"
    },
    "media-stat-2": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 0,
      "children": ["media-stat-2-value", "media-stat-2-label"]
    },
    "media-stat-2-value": {
      "type": "Text",
      "tag": "span",
      "content": "12",
      "weight": "bold"
    },
    "media-stat-2-label": {
      "type": "Text",
      "tag": "span",
      "content": "Countries",
      "variant": "muted"
    },
    "media-stat-sep-2": {
      "type": "Separator",
      "orientation": "vertical"
    },
    "media-stat-3": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 0,
      "children": ["media-stat-3-value", "media-stat-3-label"]
    },
    "media-stat-3-value": {
      "type": "Text",
      "tag": "span",
      "content": "2018",
      "weight": "bold"
    },
    "media-stat-3-label": {
      "type": "Text",
      "tag": "span",
      "content": "Founded",
      "variant": "muted"
    },
    "media-actions": {
      "type": "ButtonGroup",
      "children": ["media-learn-btn", "media-careers-btn"]
    },
    "media-learn-btn": {
      "type": "Button",
      "label": "Our Story",
      "variant": "default"
    },
    "media-careers-btn": {
      "type": "Button",
      "label": "View Open Roles",
      "variant": "outline",
      "icon": "arrow-right"
    }
  }
}
