{
  "root": "video-section",
  "elements": {
    "video-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "container": true
      },
      "children": [
        "video-header",
        "video-content"
      ]
    },
    "video-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1,
        "align": "center"
      },
      "children": [
        "video-title",
        "video-subtitle"
      ]
    },
    "video-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "See It in Action",
        "weight": "bold",
        "align": "center"
      }
    },
    "video-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Watch a 3-minute walkthrough of the platform's core features.",
        "variant": "muted",
        "align": "center"
      }
    },
    "video-content": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 4
      },
      "children": [
        "video-player",
        "video-details"
      ]
    },
    "video-player": {
      "type": "Surface",
      "props": {
        "variant": "bordered"
      },
      "children": [
        "video-player-inner"
      ]
    },
    "video-player-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "video-thumbnail",
        "video-controls"
      ]
    },
    "video-thumbnail": {
      "type": "AspectRatio",
      "props": {
        "ratio": "16/9"
      },
      "children": [
        "video-thumb-img"
      ]
    },
    "video-thumb-img": {
      "type": "Image",
      "props": {
        "src": "https://picsum.photos/seed/video-demo/800/450",
        "alt": "Video thumbnail showing the platform dashboard"
      }
    },
    "video-controls": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center",
        "justify": "center"
      },
      "children": [
        "video-play-btn",
        "video-duration"
      ]
    },
    "video-play-btn": {
      "type": "Button",
      "props": {
        "label": "Play Video",
        "variant": "default",
        "icon": "play"
      }
    },
    "video-duration": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "3:24",
        "variant": "muted"
      }
    },
    "video-details": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3,
        "justify": "center"
      },
      "children": [
        "video-details-title",
        "video-details-desc",
        "video-features",
        "video-cta"
      ]
    },
    "video-details-title": {
      "type": "Text",
      "props": {
        "tag": "h3",
        "content": "Platform Overview Demo",
        "weight": "bold"
      }
    },
    "video-details-desc": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "In this walkthrough, product lead Jamie Nguyen demonstrates real-time collaboration, the AI assistant, and the new analytics dashboard. Perfect for teams evaluating the platform.",
        "variant": "muted"
      }
    },
    "video-features": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2
      },
      "children": [
        "video-feat-1",
        "video-feat-2",
        "video-feat-3"
      ]
    },
    "video-feat-1": {
      "type": "Chip",
      "props": {
        "label": "Real-time Collab",
        "variant": "secondary"
      }
    },
    "video-feat-2": {
      "type": "Chip",
      "props": {
        "label": "AI Assistant",
        "variant": "secondary"
      }
    },
    "video-feat-3": {
      "type": "Chip",
      "props": {
        "label": "Analytics",
        "variant": "secondary"
      }
    },
    "video-cta": {
      "type": "Button",
      "props": {
        "label": "Start Free Trial",
        "variant": "default",
        "icon": "arrow-right"
      }
    }
  }
}
