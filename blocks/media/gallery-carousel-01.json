{
  "root": "gallery-carousel",
  "elements": {
    "gallery-carousel": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "container": true
      },
      "children": [
        "carousel-header",
        "carousel-featured",
        "carousel-thumbnails"
      ]
    },
    "carousel-header": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center",
        "justify": "between"
      },
      "children": [
        "carousel-header-text",
        "carousel-nav"
      ]
    },
    "carousel-header-text": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "carousel-title",
        "carousel-subtitle"
      ]
    },
    "carousel-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Featured Work",
        "weight": "bold"
      }
    },
    "carousel-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Browse through recent client projects and case studies.",
        "variant": "muted"
      }
    },
    "carousel-nav": {
      "type": "ButtonGroup",
      "children": [
        "carousel-prev",
        "carousel-next"
      ]
    },
    "carousel-prev": {
      "type": "Button",
      "props": {
        "label": "Previous",
        "variant": "outline",
        "size": "sm",
        "icon": "chevron-left"
      }
    },
    "carousel-next": {
      "type": "Button",
      "props": {
        "label": "Next",
        "variant": "outline",
        "size": "sm",
        "icon": "chevron-right"
      }
    },
    "carousel-featured": {
      "type": "Card",
      "props": {},
      "children": [
        "featured-content"
      ]
    },
    "featured-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3
      },
      "children": [
        "featured-image",
        "featured-details"
      ]
    },
    "featured-image": {
      "type": "Image",
      "props": {
        "src": "https://picsum.photos/seed/case-fintech/800/450",
        "alt": "Fintech dashboard redesign for Apex Banking",
        "height": 400
      }
    },
    "featured-details": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 4,
        "align": "center",
        "justify": "between"
      },
      "children": [
        "featured-text",
        "featured-cta"
      ]
    },
    "featured-text": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "featured-title",
        "featured-desc"
      ]
    },
    "featured-title": {
      "type": "Text",
      "props": {
        "tag": "h3",
        "content": "Apex Banking — Dashboard Redesign",
        "weight": "bold"
      }
    },
    "featured-desc": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "A complete overhaul of the consumer banking dashboard, resulting in a 28% increase in daily active usage.",
        "variant": "muted"
      }
    },
    "featured-cta": {
      "type": "Button",
      "props": {
        "label": "View Case Study",
        "variant": "outline",
        "icon": "arrow-right"
      }
    },
    "carousel-thumbnails": {
      "type": "Grid",
      "props": {
        "columns": 3,
        "gap": 2
      },
      "children": [
        "thumb-1",
        "thumb-2",
        "thumb-3"
      ]
    },
    "thumb-1": {
      "type": "Card",
      "props": {},
      "children": [
        "thumb-1-inner"
      ]
    },
    "thumb-1-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "thumb-1-img",
        "thumb-1-title"
      ]
    },
    "thumb-1-img": {
      "type": "Image",
      "props": {
        "src": "https://picsum.photos/seed/case-ecommerce/400/225",
        "alt": "E-commerce storefront",
        "height": 120
      }
    },
    "thumb-1-title": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Bloom & Branch — E-Commerce",
        "weight": "bold"
      }
    },
    "thumb-2": {
      "type": "Card",
      "props": {},
      "children": [
        "thumb-2-inner"
      ]
    },
    "thumb-2-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "thumb-2-img",
        "thumb-2-title"
      ]
    },
    "thumb-2-img": {
      "type": "Image",
      "props": {
        "src": "https://picsum.photos/seed/case-health/400/225",
        "alt": "Patient portal",
        "height": 120
      }
    },
    "thumb-2-title": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "MedSync — Patient Portal",
        "weight": "bold"
      }
    },
    "thumb-3": {
      "type": "Card",
      "props": {},
      "children": [
        "thumb-3-inner"
      ]
    },
    "thumb-3-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "thumb-3-img",
        "thumb-3-title"
      ]
    },
    "thumb-3-img": {
      "type": "Image",
      "props": {
        "src": "https://picsum.photos/seed/case-saas/400/225",
        "alt": "Analytics dashboard",
        "height": 120
      }
    },
    "thumb-3-title": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "DataPulse — Analytics",
        "weight": "bold"
      }
    }
  }
}
