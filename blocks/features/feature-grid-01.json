{
  "root": "feature-grid-section",
  "elements": {
    "feature-grid-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 5,
        "align": "center",
        "container": "wide"
      },
      "children": [
        "feature-grid-header",
        "features-grid"
      ]
    },
    "feature-grid-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "feature-grid-badge",
        "feature-grid-title",
        "feature-grid-desc"
      ]
    },
    "feature-grid-badge": {
      "type": "Badge",
      "props": {
        "text": "Features",
        "variant": "info"
      }
    },
    "feature-grid-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Everything your team needs to ship on time",
        "weight": "bold",
        "align": "center"
      }
    },
    "feature-grid-desc": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Streamline planning, tracking, and delivery with tools built for modern product teams.",
        "variant": "muted",
        "align": "center"
      }
    },
    "features-grid": {
      "type": "Grid",
      "props": {
        "columns": 3,
        "gap": 4
      },
      "children": [
        "card-boards",
        "card-timeline",
        "card-sprints",
        "card-docs",
        "card-automations",
        "card-insights"
      ]
    },
    "card-boards": {
      "type": "Card",
      "props": {
        "title": "Kanban Boards",
        "description": "Visualize work across customizable columns. Drag tasks between stages and get a real-time snapshot of progress across every workstream."
      },
      "children": [
        "icon-boards"
      ]
    },
    "icon-boards": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "layout-dashboard",
        "variant": "muted"
      }
    },
    "card-timeline": {
      "type": "Card",
      "props": {
        "title": "Gantt Timeline",
        "description": "Map dependencies and deadlines on an interactive timeline. Spot scheduling conflicts before they derail your roadmap."
      },
      "children": [
        "icon-timeline"
      ]
    },
    "icon-timeline": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "calendar-range",
        "variant": "muted"
      }
    },
    "card-sprints": {
      "type": "Card",
      "props": {
        "title": "Sprint Planning",
        "description": "Break quarterly goals into two-week sprints. Auto-assign story points and balance workload across your engineering team."
      },
      "children": [
        "icon-sprints"
      ]
    },
    "icon-sprints": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "target",
        "variant": "muted"
      }
    },
    "card-docs": {
      "type": "Card",
      "props": {
        "title": "Embedded Docs",
        "description": "Write specs, PRDs, and meeting notes right alongside your tasks. Link documents to epics for full traceability."
      },
      "children": [
        "icon-docs"
      ]
    },
    "icon-docs": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "file-text",
        "variant": "muted"
      }
    },
    "card-automations": {
      "type": "Card",
      "props": {
        "title": "Workflow Automations",
        "description": "Set rules to auto-assign reviewers, move tasks on PR merge, and notify stakeholders when milestones are hit."
      },
      "children": [
        "icon-automations"
      ]
    },
    "icon-automations": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "zap",
        "variant": "muted"
      }
    },
    "card-insights": {
      "type": "Card",
      "props": {
        "title": "Team Insights",
        "description": "Track velocity, cycle time, and throughput with built-in analytics. Identify bottlenecks and celebrate wins with weekly reports."
      },
      "children": [
        "icon-insights"
      ]
    },
    "icon-insights": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "bar-chart-2",
        "variant": "muted"
      }
    }
  }
}
