{
  "root": "feature-icon-grid-section",
  "elements": {
    "feature-icon-grid-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 5,
        "align": "center",
        "container": "wide"
      },
      "children": [
        "icon-grid-header",
        "icon-grid"
      ]
    },
    "icon-grid-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "icon-grid-title",
        "icon-grid-desc"
      ]
    },
    "icon-grid-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Everything you need in one workspace",
        "weight": "bold",
        "align": "center"
      }
    },
    "icon-grid-desc": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Flowdesk brings together 24 tools your team already uses into a single productivity suite.",
        "variant": "muted",
        "align": "center"
      }
    },
    "icon-grid": {
      "type": "Grid",
      "props": {
        "columns": 4,
        "gap": 3
      },
      "children": [
        "ig-docs",
        "ig-sheets",
        "ig-slides",
        "ig-mail",
        "ig-calendar",
        "ig-tasks",
        "ig-chat",
        "ig-video",
        "ig-forms",
        "ig-notes",
        "ig-files",
        "ig-whiteboard"
      ]
    },
    "ig-docs": {
      "type": "Stack",
