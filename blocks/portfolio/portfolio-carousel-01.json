{
  "root": "portfolio-carousel",
  "elements": {
    "portfolio-carousel": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "container": true
      },
      "children": [
        "pc-header-row",
        "pc-featured",
        "pc-grid"
      ]
    },
    "pc-header-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center",
        "justify": "between"
      },
      "children": [
        "pc-header-text",
        "pc-nav-btns"
      ]
    },
    "pc-header-text": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "pc-heading",
        "pc-subheading"
      ]
    },
    "pc-heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Featured Projects",
        "weight": "bold"
      }
    },
    "pc-subheading": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Swipe through our latest case studies and client work.",
        "variant": "muted"
      }
    },
    "pc-nav-btns": {
      "type": "ButtonGroup",
      "children": [
        "pc-prev",
        "pc-next"
      ]
    },
    "pc-prev": {
      "type": "Button",
      "props": {
        "label": "Previous",
        "variant": "outline",
        "icon": "chevron-left"
      }
    },
    "pc-next": {
      "type": "Button",
      "props": {
        "label": "Next",
        "variant": "outline",
        "icon": "chevron-right"
      }
    },
    "pc-featured": {
      "type": "Card",
      "props": {},
      "children": [
        "pc-featured-inner"
      ]
    },
    "pc-featured-inner": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 4,
        "align": "center"
      },
      "children": [
        "pc-featured-img",
        "pc-featured-info"
      ]
    },
    "pc-featured-img": {
      "type": "Image",
      "props": {
        "src": "https://picsum.photos/seed/carousel-atlas/700/450",
        "alt": "Atlas CRM Dashboard",
        "width": 400,
        "height": 260
      }
    },
    "pc-featured-info": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "pc-featured-client",
        "pc-featured-title",
        "pc-featured-desc",
        "pc-featured-link"
      ]
    },
    "pc-featured-client": {
      "type": "Chip",
      "props": {
        "label": "Atlas Corp",
        "variant": "primary"
      }
    },
    "pc-featured-title": {
      "type": "Text",
      "props": {
        "tag": "h3",
        "content": "Enterprise CRM Redesign",
        "weight": "bold"
      }
    },
    "pc-featured-desc": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Redesigned the entire CRM experience for 25,000 sales reps. Reduced average task completion time by 34% and boosted user adoption from 62% to 91%.",
        "variant": "muted"
      }
    },
    "pc-featured-link": {
      "type": "Button",
      "props": {
        "label": "View Case Study",
        "variant": "outline",
        "icon": "arrow-right"
      }
    },
    "pc-grid": {
      "type": "Grid",
      "props": {
        "columns": 3,
        "gap": 2
      },
      "children": [
        "pc-card-2",
        "pc-card-3",
        "pc-card-4"
      ]
    },
    "pc-card-2": {
      "type": "Card",
      "props": {},
      "children": [
        "pc-card-2-inner"
      ]
    },
    "pc-card-2-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "pc-card-2-img",
        "pc-card-2-title",
        "pc-card-2-desc"
      ]
    },
    "pc-card-2-img": {
      "type": "Image",
      "props": {
        "src": "https://picsum.photos/seed/carousel-bloom/400/225",
        "alt": "Bloom Marketplace",
        "height": 140
      }
    },
    "pc-card-2-title": {
      "type": "Text",
      "props": {
        "tag": "h4",
        "content": "Artisan Marketplace Platform",
        "weight": "bold"
      }
    },
    "pc-card-2-desc": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Two-sided marketplace connecting 3,000 artisans with buyers.",
        "variant": "muted"
      }
    },
    "pc-card-3": {
      "type": "Card",
      "props": {},
      "children": [
        "pc-card-3-inner"
      ]
    },
    "pc-card-3-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "pc-card-3-img",
        "pc-card-3-title",
        "pc-card-3-desc"
      ]
    },
    "pc-card-3-img": {
      "type": "Image",
      "props": {
        "src": "https://picsum.photos/seed/carousel-nova/400/225",
        "alt": "Nova Streaming",
        "height": 140
      }
    },
    "pc-card-3-title": {
      "type": "Text",
      "props": {
        "tag": "h4",
        "content": "Live Streaming Platform",
        "weight": "bold"
      }
    },
    "pc-card-3-desc": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Low-latency streaming supporting 200K concurrent viewers.",
        "variant": "muted"
      }
    },
    "pc-card-4": {
      "type": "Card",
      "props": {},
      "children": [
        "pc-card-4-inner"
      ]
    },
    "pc-card-4-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "pc-card-4-img",
        "pc-card-4-title",
        "pc-card-4-desc"
      ]
    },
    "pc-card-4-img": {
      "type": "Image",
      "props": {
        "src": "https://picsum.photos/seed/carousel-verde/400/225",
        "alt": "Verde Sustainability",
        "height": 140
      }
    },
    "pc-card-4-title": {
      "type": "Text",
      "props": {
        "tag": "h4",
        "content": "Carbon Tracking Dashboard",
        "weight": "bold"
      }
    },
    "pc-card-4-desc": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Real-time carbon footprint tracker for 120 enterprises.",
        "variant": "muted"
      }
    }
  }
}
