{
  "root": "portfolio-grid",
  "elements": {
    "portfolio-grid": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "container": true
      },
      "children": [
        "pg-header",
        "pg-sub",
        "pg-filters",
        "pg-projects"
      ]
    },
    "pg-header": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Our Work",
        "weight": "bold",
        "align": "center"
      }
    },
    "pg-sub": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Selected projects from our portfolio spanning brand, product, and platform design.",
        "variant": "muted",
        "align": "center"
      }
    },
    "pg-filters": {
      "type": "ToggleGroup",
      "props": {
        "items": [
          {
            "label": "All",
            "active": true
          },
          {
            "label": "Web Apps"
          },
          {
            "label": "Mobile"
          },
          {
            "label": "Branding"
          },
          {
            "label": "E-Commerce"
          }
        ]
      }
    },
    "pg-projects": {
      "type": "Grid",
      "props": {
        "columns": 3,
        "gap": 3
      },
      "children": [
        "pg-proj-1",
        "pg-proj-2",
        "pg-proj-3",
        "pg-proj-4",
        "pg-proj-5",
        "pg-proj-6"
      ]
    },
    "pg-proj-1": {
      "type": "Card",
      "children": [
        "pg-p1-inner"
      ]
    },
    "pg-p1-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "pg-p1-img",
        "pg-p1-title",
        "pg-p1-desc",
        "pg-p1-tags"
      ]
    },
    "pg-p1-img": {
      "type": "Image",
      "props": {
        "src": "https://picsum.photos/seed/proj-fintech/600/400",
        "alt": "Meridian Finance Dashboard"
      }
    },
    "pg-p1-title": {
      "type": "Text",
      "props": {
        "tag": "h4",
        "content": "Meridian Finance",
        "weight": "bold"
      }
    },
    "pg-p1-desc": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Real-time trading dashboard for a fintech startup. Handles 50K concurrent users.",
        "variant": "muted"
      }
    },
    "pg-p1-tags": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1
      },
      "children": [
        "pg-p1-t1",
        "pg-p1-t2"
      ]
    },
    "pg-p1-t1": {
      "type": "Chip",
      "props": {
        "label": "Web App"
      }
    },
    "pg-p1-t2": {
      "type": "Chip",
      "props": {
        "label": "React"
      }
    },
    "pg-proj-2": {
      "type": "Card",
      "children": [
        "pg-p2-inner"
      ]
    },
    "pg-p2-inner": {
      "type": "Stack",
