{
  "root": "navbar-search",
  "elements": {
    "navbar-search": {
      "type": "Navbar",
      "props": {
        "brand": "Coppice",
        "items": [
          {
            "label": "Explore",
            "href": "/explore"
          },
          {
            "label": "Collections",
            "href": "/collections"
          },
          {
            "label": "Trending",
            "href": "/trending"
          }
        ],
        "actions": [
          "search-actions"
        ]
      }
    },
    "search-actions": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3,
        "align": "center"
      },
      "children": [
        "nav-search-input",
        "nav-search-cart",
        "nav-search-avatar"
      ]
    },
    "nav-search-input": {
      "type": "Search",
      "props": {
        "placeholder": "Search products, brands, categories..."
      }
    },
    "nav-search-cart": {
      "type": "Button",
      "props": {
        "label": "Cart",
        "variant": "ghost",
        "size": "sm",
        "icon": "shopping-cart"
      }
    },
    "nav-search-avatar": {
      "type": "Avatar",
      "props": {
        "initials": "KW",
        "size": "sm"
      }
    }
  }
}
