{
  "root": "mobile-nav-wrapper",
  "elements": {
    "mobile-nav-wrapper": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "mobile-navbar",
        "mobile-drawer"
      ]
    },
    "mobile-navbar": {
      "type": "Navbar",
      "props": {
        "brand": "Nomadly",
        "items": [],
        "actions": [
          "hamburger-btn"
        ]
      }
    },
    "hamburger-btn": {
      "type": "Button",
      "props": {
        "label": "Menu",
        "variant": "ghost",
        "size": "sm",
        "icon": "menu"
      }
    },
    "mobile-drawer": {
      "type": "Sheet",
      "props": {
        "side": "left"
      },
      "children": [
        "drawer-content"
      ]
    },
    "drawer-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "drawer-header",
        "drawer-sep",
        "drawer-nav",
        "drawer-sep-2",
        "drawer-auth"
      ]
    },
    "drawer-header": {
      "type": "Text",
      "props": {
        "tag": "h5",
        "content": "Nomadly",
        "weight": "bold"
      }
    },
    "drawer-sep": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "drawer-nav": {
      "type": "NavMenu",
      "props": {
        "direction": "vertical",
        "items": [
          {
            "label": "Destinations",
            "icon": "map-pin",
            "href": "/destinations"
          },
          {
            "label": "Trips",
            "icon": "compass",
            "href": "/trips",
            "active": true
          },
          {
            "label": "Guides",
            "icon": "book-open",
            "href": "/guides"
          },
          {
            "label": "Community",
            "icon": "users",
            "href": "/community"
          },
          {
            "label": "Gear Shop",
            "icon": "shopping-bag",
            "href": "/shop"
          }
        ]
      }
    },
    "drawer-sep-2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "drawer-auth": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "drawer-login-btn",
        "drawer-signup-btn"
      ]
    },
    "drawer-login-btn": {
      "type": "Button",
      "props": {
        "label": "Log In",
        "variant": "outline"
      }
    },
    "drawer-signup-btn": {
      "type": "Button",
      "props": {
        "label": "Sign Up Free",
        "variant": "primary"
      }
    }
  }
}
