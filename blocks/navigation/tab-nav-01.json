{
  "root": "tab-nav-wrapper",
  "elements": {
    "tab-nav-wrapper": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 4,
      "children": ["tab-nav-header", "tab-nav-tabs"]
    },
    "tab-nav-header": {
      "type": "Stack",
      "direction": "horizontal",
      "gap": 3,
      "align": "center",
      "justify": "between",
      "children": ["tab-nav-title", "tab-nav-actions"]
    },
    "tab-nav-title": {
      "type": "Text",
      "tag": "h3",
      "content": "Account Settings",
      "weight": "bold"
    },
    "tab-nav-actions": {
      "type": "Button",
      "label": "Save Changes",
      "variant": "primary",
      "size": "sm"
    },
    "tab-nav-tabs": {
      "type": "Tabs",
      "items": [
        { "label": "General", "content": "general-panel" },
        { "label": "Security", "content": "security-panel" },
        { "label": "Notifications", "content": "notifications-panel" },
        { "label": "Integrations", "content": "integrations-panel" },
        { "label": "API Keys", "content": "api-panel" }
      ]
    },
    "general-panel": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 3,
      "children": ["general-name-field", "general-email-field", "general-timezone-field"]
    },
    "general-name-field": {
      "type": "Field",
      "label": "Display Name",
      "placeholder": "Enter your display name"
    },
    "general-email-field": {
      "type": "Field",
      "label": "Email Address",
      "placeholder": "you@company.com",
      "type": "email"
    },
    "general-timezone-field": {
      "type": "Select",
      "label": "Timezone",
      "placeholder": "Select timezone"
    },
    "security-panel": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 3,
      "children": ["security-password-field", "security-2fa-toggle"]
    },
    "security-password-field": {
      "type": "Field",
      "label": "Current Password",
      "placeholder": "Enter current password",
      "type": "password"
    },
    "security-2fa-toggle": {
      "type": "Switch",
      "label": "Enable Two-Factor Authentication"
    },
    "notifications-panel": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 3,
      "children": ["notif-email-switch", "notif-push-switch", "notif-weekly-switch"]
    },
    "notif-email-switch": {
      "type": "Switch",
      "label": "Email Notifications"
    },
    "notif-push-switch": {
      "type": "Switch",
      "label": "Push Notifications"
    },
    "notif-weekly-switch": {
      "type": "Switch",
      "label": "Weekly Digest"
    },
    "integrations-panel": {
      "type": "Text",
      "tag": "p",
      "content": "Connect your favorite tools to streamline your workflow.",
      "variant": "muted"
    },
    "api-panel": {
      "type": "Text",
      "tag": "p",
      "content": "Manage your API keys and access tokens.",
      "variant": "muted"
    }
  }
}
