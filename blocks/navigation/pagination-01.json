{
  "root": "pagination-wrapper",
  "elements": {
    "pagination-wrapper": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "pagination-info",
        "pagination-controls"
      ]
    },
    "pagination-info": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "justify": "between",
        "align": "center"
      },
      "children": [
        "pagination-showing",
        "pagination-per-page"
      ]
    },
    "pagination-showing": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Showing 41-60 of 2,847 results",
        "variant": "muted"
      }
    },
    "pagination-per-page": {
      "type": "Select",
      "props": {
        "label": "Per page",
        "placeholder": "20"
      }
    },
    "pagination-controls": {
      "type": "Pagination",
      "props": {
        "total": 2847,
        "current": 3,
        "pageSize": 20
      }
    }
  }
}
