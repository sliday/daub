          },
          {
            "primary": "Payment received from Acme Corp",
            "secondary": "Enterprise invoice #INV-2041 settled",
            "icon": "CreditCard",
            "meta": "6 hrs ago"
          }
        ]
      }
    },
    "performance-card": {
      "type": "Card",
      "props": {
        "title": "Performance"
      },
      "children": [
        "performance-list"
      ]
    },
    "performance-list": {
      "type": "List",
      "props": {
        "items": [
          {
            "primary": "Server Uptime",
            "secondary": "Last 30 days",
            "meta": "99.98%"
          },
          {
            "primary": "Avg. Response Time",
            "secondary": "API endpoints",
            "meta": "142ms"
          },
          {
            "primary": "Support Tickets Open",
            "secondary": "3 high priority",
            "meta": "17"
          },
          {
            "primary": "NPS Score",
            "secondary": "Q1 2026 survey",
            "meta": "72"
          },
          {
            "primary": "Monthly Churn",
            "secondary": "Down from 4.1%",
            "meta": "2.8%"
          }
        ]
      }
    }
  }
}
