{
  "root": "dashboard-header",
  "elements": {
    "dashboard-header": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "justify": "space-between",
        "align": "center",
        "gap": 4
      },
      "children": [
        "header-left",
        "header-right"
      ]
    },
    "header-left": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "page-title",
        "page-subtitle"
      ]
    },
    "page-title": {
      "type": "Text",
      "props": {
        "tag": "h1",
        "content": "Dashboard",
        "weight": "bold"
      }
    },
    "page-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Welcome back, Sarah. Here's what's happening today.",
        "variant": "muted"
      }
    },
    "header-right": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "date-picker",
        "btn-refresh",
        "btn-add-new"
      ]
    },
    "date-picker": {
      "type": "DatePicker",
      "props": {
        "label": "Date Range",
        "placeholder": "Mar 1 - Mar 10, 2026"
      }
    },
    "btn-refresh": {
      "type": "Button",
      "props": {
        "label": "Refresh",
        "variant": "outline",
        "size": "sm",
        "icon": "refresh-cw"
      }
    },
    "btn-add-new": {
      "type": "Button",
      "props": {
        "label": "Add Widget",
        "variant": "default",
        "size": "sm",
        "icon": "plus"
      }
    }
  }
}
