{
  "root": "empty-state-section",
  "elements": {
    "empty-state-section": {
      "type": "Surface",
      "variant": "bordered",
      "children": ["empty-content"]
    },
    "empty-content": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 4,
      "align": "center",
      "children": ["empty-placeholder", "empty-actions"]
    },
    "empty-placeholder": {
      "type": "EmptyState",
      "title": "No reports yet",
      "description": "Create your first report to start tracking performance metrics and visualizing your data.",
      "icon": "bar-chart-2"
    },
    "empty-actions": {
      "type": "Stack",
      "direction": "horizontal",
      "gap": 2,
      "align": "center",
      "children": ["btn-create-report", "btn-import"]
    },
    "btn-create-report": {
      "type": "Button",
      "label": "Create Report",
      "variant": "default",
      "icon": "plus"
    },
    "btn-import": {
      "type": "Button",
      "label": "Import Data",
      "variant": "outline",
      "icon": "upload"
    }
  }
}
