{
  "root": "register-form",
  "elements": {
    "register-form": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0,
        "align": "center",
        "justify": "center",
        "container": "narrow"
      },
      "children": [
        "register-card"
      ]
    },
    "register-card": {
      "type": "Card",
      "props": {
        "title": "Create your account",
        "description": "Start your 14-day free trial. No credit card required."
      },
      "children": [
        "card-body"
      ]
    },
    "card-body": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "name-row",
        "email-field",
        "password-field",
        "confirm-password-field",
        "terms-check",
        "register-btn",
        "divider",
        "login-prompt"
      ]
    },
    "name-row": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 4
      },
      "children": [
        "first-name-field",
        "last-name-field"
      ]
    },
    "first-name-field": {
      "type": "Field",
      "props": {
        "label": "First Name"
      },
      "children": [
        "first-name-input"
      ]
    },
    "first-name-input": {
      "type": "Input",
      "props": {
        "placeholder": "Jane"
      }
    },
    "last-name-field": {
      "type": "Field",
      "props": {
        "label": "Last Name"
      },
      "children": [
        "last-name-input"
      ]
    },
    "last-name-input": {
      "type": "Input",
      "props": {
        "placeholder": "Smith"
      }
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email Address"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "jane@company.com",
        "type": "email"
      }
    },
    "password-field": {
      "type": "Field",
      "props": {
        "label": "Password"
      },
      "children": [
        "password-input"
      ]
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "Create a strong password",
        "type": "password"
      }
    },
    "confirm-password-field": {
      "type": "Field",
      "props": {
        "label": "Confirm Password"
      },
      "children": [
        "confirm-password-input"
      ]
    },
    "confirm-password-input": {
      "type": "Input",
      "props": {
        "placeholder": "Re-enter your password",
        "type": "password"
      }
    },
    "terms-check": {
      "type": "Checkbox",
      "props": {
        "label": "I agree to the Terms of Service and Privacy Policy",
        "checked": false
      }
    },
    "register-btn": {
      "type": "Button",
      "props": {
        "label": "Create Account",
        "variant": "primary",
        "size": "lg"
      }
    },
    "divider": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "login-prompt": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1,
        "align": "center",
        "justify": "center"
      },
      "children": [
        "login-text",
        "login-link"
      ]
    },
    "login-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Already have an account?",
        "variant": "muted"
      }
    },
    "login-link": {
      "type": "Button",
      "props": {
        "label": "Sign in",
        "variant": "ghost",
        "size": "sm"
      }
    }
  }
}
