{
  "root": "login-page-card-02",
  "elements": {
    "login-page-card-02": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 0, "align": "center", "justify": "center", "container": "narrow" },
      "children": ["login-card"]
    },

    "login-card": {
      "type": "Card",
      "props": {},
      "children": ["card-body"]
    },
    "card-body": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 5 },
      "children": ["header", "fields-group", "options-row", "signin-btn", "google-btn", "signup-prompt"]
    },

    "header": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 4, "align": "center" },
      "children": ["logo-icon", "header-title", "header-subtitle"]
    },
    "logo-icon": {
      "type": "Icon",
      "props": { "name": "circle", "size": "sm", "variant": "branded" }
    },
    "header-title": {
      "type": "Text",
      "props": { "tag": "h2", "content": "Welcome back", "align": "center" }
    },
    "header-subtitle": {
      "type": "Text",
      "props": { "tag": "p", "content": "Please enter your details.", "variant": "secondary", "align": "center" }
    },

    "fields-group": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 4 },
      "children": ["email-input", "password-input"]
    },
    "email-input": {
      "type": "Input",
      "props": { "placeholder": "Enter your email", "type": "email" }
    },
    "password-input": {
      "type": "Input",
      "props": { "placeholder": "\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022", "type": "password" }
    },

    "options-row": {
      "type": "Stack",
      "props": { "direction": "horizontal", "gap": 0, "justify": "between", "align": "center" },
      "children": ["remember-check", "forgot-link"]
    },
    "remember-check": {
      "type": "Checkbox",
      "props": { "label": "Remember for 30 days", "checked": false }
    },
    "forgot-link": {
      "type": "Button",
      "props": { "label": "Forgot password", "variant": "ghost", "size": "sm" }
    },

    "signin-btn": {
      "type": "Button",
      "props": { "label": "Sign in", "variant": "primary", "size": "lg", "fullWidth": true }
    },
    "google-btn": {
      "type": "Button",
      "props": { "label": "Sign in with Google", "variant": "outline", "size": "lg", "fullWidth": true, "icon": "google" }
    },

    "signup-prompt": {
      "type": "Stack",
      "props": { "direction": "horizontal", "gap": 1, "align": "center", "justify": "center" },
      "children": ["signup-text", "signup-link"]
    },
    "signup-text": {
      "type": "Text",
      "props": { "tag": "p", "content": "Don't have an account?", "variant": "secondary" }
    },
    "signup-link": {
      "type": "Button",
      "props": { "label": "Sign up", "variant": "ghost", "size": "sm" }
    }
  }
}
