{
  "root": "forgot-password-check-email",
  "elements": {
    "forgot-password-check-email": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 8,
        "align": "center",
        "justify": "center",
        "container": "narrow"
      },
      "children": [
        "header",
        "content",
        "resend-row",
        "back-btn"
      ]
    },
    "header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "align": "center"
      },
      "children": [
        "featured-icon",
        "header-text"
      ]
    },
    "featured-icon": {
      "type": "Icon",
      "props": {
        "name": "mail",
        "size": "lg",
        "variant": "branded"
      }
    },
    "header-text": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3,
        "align": "center"
      },
      "children": [
        "title",
        "subtitle"
      ]
    },
    "title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Check your email",
        "align": "center"
      }
    },
    "subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "We sent a password reset link to\nolivia@daub.sh",
        "variant": "secondary",
        "align": "center"
      }
    },
    "content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "open-email-btn"
      ]
    },
    "open-email-btn": {
      "type": "Button",
      "props": {
        "label": "Open email app",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "resend-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1,
        "align": "center",
        "justify": "center"
      },
      "children": [
        "resend-text",
        "resend-link"
      ]
    },
    "resend-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Didn't receive the email?",
        "variant": "secondary"
      }
    },
    "resend-link": {
      "type": "Link",
      "props": {
        "label": "Click to resend"
      }
    },
    "back-btn": {
      "type": "Link",
      "props": {
        "label": "Back to log in"
      }
    }
  }
}
