{
  "root": "login-page-social",
  "elements": {
    "login-page-social": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0,
        "align": "center",
        "justify": "center",
        "container": "narrow"
      },
      "children": [
        "main-content"
      ]
    },
    "main-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "align": "center"
      },
      "children": [
        "header",
        "form-section",
        "signup-prompt"
      ]
    },
    "header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "align": "center"
      },
      "children": [
        "logo",
        "heading",
        "subtitle"
      ]
    },
    "logo": {
      "type": "Surface",
      "props": {
        "variant": "elevated",
        "padding": 3
      },
      "children": [
        "logo-icon"
      ]
    },
    "logo-icon": {
      "type": "Icon",
      "props": {
        "name": "layers"
      }
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Log in to your account",
        "align": "center"
      }
    },
    "subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Welcome back! Please enter your details.",
        "variant": "secondary",
        "align": "center"
      }
    },
    "form-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "align": "stretch"
      },
      "children": [
        "email-input",
        "continue-email-btn",
        "divider",
        "google-btn",
        "facebook-btn",
        "apple-btn"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      }
    },
    "continue-email-btn": {
      "type": "Button",
      "props": {
        "label": "Continue with email",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "divider": {
      "type": "Separator",
      "props": {
        "label": "OR"
      }
    },
    "google-btn": {
      "type": "Button",
      "props": {
        "label": "Continue with Google",
        "variant": "outline",
        "size": "lg",
        "icon": "google",
        "fullWidth": true
      }
    },
    "facebook-btn": {
      "type": "Button",
      "props": {
        "label": "Continue with Facebook",
        "variant": "outline",
        "size": "lg",
        "icon": "facebook",
        "fullWidth": true
      }
    },
    "apple-btn": {
      "type": "Button",
      "props": {
        "label": "Continue with Apple",
        "variant": "outline",
        "size": "lg",
        "icon": "apple",
        "fullWidth": true
      }
    },
    "signup-prompt": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1,
        "align": "center",
        "justify": "center"
      },
      "children": [
        "signup-text",
        "signup-link"
      ]
    },
    "signup-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Don't have an account?",
        "variant": "secondary"
      }
    },
    "signup-link": {
      "type": "Button",
      "props": {
        "label": "Sign up",
        "variant": "ghost",
        "size": "sm"
      }
    }
  }
}
