{
  "root": "signup-split-gradient",
  "elements": {
    "signup-split-gradient": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 0
      },
      "children": [
        "form-panel",
        "gradient-panel"
      ]
    },
    "form-panel": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "nav-bar",
        "form-container",
        "form-footer"
      ]
    },
    "nav-bar": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center",
        "padding": [
          3,
          4
        ]
      },
      "children": [
        "nav-logo"
      ]
    },
    "nav-logo": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "logo-icon",
        "logo-text"
      ]
    },
    "logo-icon": {
      "type": "Icon",
      "props": {
        "name": "layers",
        "size": "md"
      }
    },
    "logo-text": {
      "type": "Text",
      "props": {
        "tag": "h4",
        "content": "Daub"
      }
    },
    "form-container": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "justify": "center",
        "padding": [
          4,
          8
        ]
      },
      "children": [
        "form-header",
        "form-fields",
        "form-login"
      ]
    },
    "form-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "form-title",
        "form-subtitle"
      ]
    },
    "form-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Sign up"
      }
    },
    "form-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Start your 30-day free trial.",
        "variant": "secondary"
      }
    },
    "form-fields": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "name-field",
        "email-field",
        "password-field",
        "signup-btn",
        "google-btn"
      ]
    },
    "name-field": {
      "type": "Field",
      "props": {
        "label": "Name*"
      },
      "children": [
        "name-input"
      ]
    },
    "name-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your name",
        "type": "text"
      }
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email*"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      }
    },
    "password-field": {
      "type": "Field",
      "props": {
        "label": "Password*",
        "hint": "Must be at least 8 characters."
      },
      "children": [
        "password-input"
      ]
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "Create a password",
        "type": "password"
      }
    },
    "signup-btn": {
      "type": "Button",
      "props": {
        "label": "Get started",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "google-btn": {
      "type": "Button",
      "props": {
        "label": "Sign up with Google",
        "variant": "outline",
        "size": "lg",
        "icon": "google",
        "fullWidth": true
      }
    },
    "form-login": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1,
        "align": "center"
      },
      "children": [
        "login-text",
        "login-link"
      ]
    },
    "login-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Already have an account?",
        "variant": "secondary"
      }
    },
    "login-link": {
      "type": "Link",
      "props": {
        "label": "Log in"
      }
    },
    "form-footer": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "padding": [
          2,
          4
        ]
      },
      "children": [
        "footer-text"
      ]
    },
    "footer-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "© Daub 2026",
        "variant": "secondary"
      }
    },
    "gradient-panel": {
      "type": "Surface",
      "props": {
        "variant": "brand",
        "padding": 0
      },
      "children": []
    }
  }
}
