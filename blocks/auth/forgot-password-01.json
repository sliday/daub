{
  "root": "forgot-password",
  "elements": {
    "forgot-password": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 0,
      "align": "center",
      "justify": "center",
      "container": "narrow",
      "children": ["forgot-card"]
    },
    "forgot-card": {
      "type": "Card",
      "title": "Reset your password",
      "description": "Enter the email address associated with your account and we'll send you a link to reset your password.",
      "children": ["card-body"]
    },
    "card-body": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 4,
      "children": ["info-alert", "email-field", "reset-btn", "divider", "back-row"]
    },
    "info-alert": {
      "type": "Alert",
      "variant": "info",
      "title": "Check your inbox",
      "description": "If an account exists for the email you enter, you'll receive a password reset link within a few minutes."
    },
    "email-field": {
      "type": "Field",
      "label": "Email Address",
      "children": ["email-input"]
    },
    "email-input": {
      "type": "Input",
      "type": "email",
      "placeholder": "you@example.com"
    },
    "reset-btn": {
      "type": "Button",
      "label": "Send Reset Link",
      "variant": "primary",
      "size": "lg"
    },
    "divider": {
      "type": "Separator",
      "orientation": "horizontal"
    },
    "back-row": {
      "type": "Stack",
      "direction": "horizontal",
      "gap": 1,
      "align": "center",
      "justify": "center",
      "children": ["back-text", "back-link"]
    },
    "back-text": {
      "type": "Text",
      "tag": "p",
      "content": "Remember your password?",
      "variant": "muted"
    },
    "back-link": {
      "type": "Button",
      "label": "Back to sign in",
      "variant": "ghost",
      "size": "sm"
    }
  }
}