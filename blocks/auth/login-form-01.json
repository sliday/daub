{
  "root": "login-form",
  "elements": {
    "login-form": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0,
        "align": "center",
        "justify": "center",
        "container": "narrow"
      },
      "children": [
        "login-card"
      ]
    },
    "login-card": {
      "type": "Card",
      "props": {
        "title": "Welcome back",
        "description": "Sign in to your account to continue"
      },
      "children": [
        "card-body"
      ]
    },
    "card-body": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "email-field",
        "password-field",
        "options-row",
        "login-btn",
        "divider-row",
        "signup-text"
      ]
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "you@example.com",
        "type": "email"
      }
    },
    "password-field": {
      "type": "Field",
      "props": {
        "label": "Password"
      },
      "children": [
        "password-input"
      ]
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your password",
        "type": "password"
      }
    },
    "options-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 0,
        "align": "center",
        "justify": "between"
      },
      "children": [
        "remember-check",
        "forgot-link"
      ]
    },
    "remember-check": {
      "type": "Checkbox",
      "props": {
        "label": "Remember me",
        "checked": false
      }
    },
    "forgot-link": {
      "type": "Link",
      "props": {
        "label": "Forgot password?"
      }
    },
    "login-btn": {
      "type": "Button",
      "props": {
        "label": "Sign In",
        "variant": "primary",
        "size": "lg"
      }
    },
    "divider-row": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "signup-text": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1,
        "align": "center",
        "justify": "center"
      },
      "children": [
        "no-account-text",
        "signup-link"
      ]
    },
    "no-account-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Don't have an account?",
        "variant": "muted"
      }
    },
    "signup-link": {
      "type": "Link",
      "props": {
        "label": "Sign up"
      }
    }
  }
}
