{
  "root": "forgot-password-form",
  "elements": {
    "forgot-password-form": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 8,
        "align": "center",
        "justify": "center",
        "container": "narrow"
      },
      "children": [
        "header",
        "content",
        "back-btn"
      ]
    },
    "header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "align": "center"
      },
      "children": [
        "featured-icon",
        "header-text"
      ]
    },
    "featured-icon": {
      "type": "Icon",
      "props": {
        "name": "key",
        "size": "lg",
        "variant": "branded"
      }
    },
    "header-text": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3,
        "align": "center"
      },
      "children": [
        "title",
        "subtitle"
      ]
    },
    "title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Forgot password?",
        "align": "center"
      }
    },
    "subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "No worries, we'll send you reset instructions.",
        "variant": "secondary",
        "align": "center"
      }
    },
    "content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6
      },
      "children": [
        "email-field",
        "reset-btn"
      ]
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      }
    },
    "reset-btn": {
      "type": "Button",
      "props": {
        "label": "Reset password",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "back-btn": {
      "type": "Link",
      "props": {
        "label": "Back to log in"
      }
    }
  }
}
