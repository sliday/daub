{
  "root": "signup-split-carousel",
  "elements": {
    "signup-split-carousel": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 0
      },
      "children": [
        "form-panel",
        "carousel-panel"
      ]
    },
    "form-panel": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "nav-bar",
        "form-container",
        "form-footer"
      ]
    },
    "nav-bar": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center",
        "padding": [
          3,
          4
        ]
      },
      "children": [
        "nav-logo"
      ]
    },
    "nav-logo": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "logo-icon",
        "logo-text"
      ]
    },
    "logo-icon": {
      "type": "Icon",
      "props": {
        "name": "layers",
        "size": "md"
      }
    },
    "logo-text": {
      "type": "Text",
      "props": {
        "tag": "h4",
        "content": "Daub"
      }
    },
    "form-container": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "justify": "center",
        "padding": [
          4,
          8
        ]
      },
      "children": [
        "form-header",
        "form-fields",
        "form-login"
      ]
    },
    "form-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "form-title",
        "form-subtitle"
      ]
    },
    "form-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Sign up"
      }
    },
    "form-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Start your 30-day free trial.",
        "variant": "secondary"
      }
    },
    "form-fields": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "name-field",
        "email-field",
        "password-field",
        "signup-btn",
        "google-btn"
      ]
    },
    "name-field": {
      "type": "Field",
      "props": {
        "label": "Name*"
      },
      "children": [
        "name-input"
      ]
    },
    "name-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your name",
        "type": "text"
      }
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email*"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      }
    },
    "password-field": {
      "type": "Field",
      "props": {
        "label": "Password*",
        "hint": "Must be at least 8 characters."
      },
      "children": [
        "password-input"
      ]
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "Create a password",
        "type": "password"
      }
    },
    "signup-btn": {
      "type": "Button",
      "props": {
        "label": "Get started",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "google-btn": {
      "type": "Button",
      "props": {
        "label": "Sign up with Google",
        "variant": "outline",
        "size": "lg",
        "icon": "google",
        "fullWidth": true
      }
    },
    "form-login": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1,
        "align": "center"
      },
      "children": [
        "login-text",
        "login-link"
      ]
    },
    "login-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Already have an account?",
        "variant": "secondary"
      }
    },
    "login-link": {
      "type": "Link",
      "props": {
        "label": "Log in"
      }
    },
    "form-footer": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "padding": [
          2,
          4
        ]
      },
      "children": [
        "footer-text"
      ]
    },
    "footer-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "© Daub 2026",
        "variant": "secondary"
      }
    },
    "carousel-panel": {
      "type": "Surface",
      "props": {
        "variant": "brand",
        "padding": 6
      },
      "children": [
        "carousel-inner"
      ]
    },
    "carousel-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "justify": "center",
        "align": "center"
      },
      "children": [
        "carousel-slide",
        "carousel-caption",
        "carousel-nav"
      ]
    },
    "carousel-slide": {
      "type": "Surface",
      "props": {
        "variant": "elevated",
        "padding": 4
      },
      "children": [
        "slide-image"
      ]
    },
    "slide-image": {
      "type": "Image",
      "props": {
        "src": "data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22500%22%20height%3D%22350%22%20viewBox%3D%220%200%20500%20350%22%3E%3Crect%20width%3D%22500%22%20height%3D%22350%22%20rx%3D%2212%22%20fill%3D%22%23F2F4F7%22%2F%3E%3Ctext%20x%3D%2240%22%20y%3D%2240%22%20font-family%3D%22system-ui%2Csans-serif%22%20font-size%3D%2218%22%20font-weight%3D%22600%22%20fill%3D%22%23344054%22%3EUsers%20over%20time%3C%2Ftext%3E%3Cline%20x1%3D%2240%22%20y1%3D%2280%22%20x2%3D%22420%22%20y2%3D%2280%22%20stroke%3D%22%23E4E7EC%22%20stroke-width%3D%221%22%2F%3E%3Cline%20x1%3D%2240%22%20y1%3D%22130%22%20x2%3D%22420%22%20y2%3D%22130%22%20stroke%3D%22%23E4E7EC%22%20stroke-width%3D%221%22%2F%3E%3Cline%20x1%3D%2240%22%20y1%3D%22180%22%20x2%3D%22420%22%20y2%3D%22180%22%20stroke%3D%22%23E4E7EC%22%20stroke-width%3D%221%22%2F%3E%3Cline%20x1%3D%2240%22%20y1%3D%22230%22%20x2%3D%22420%22%20y2%3D%22230%22%20stroke%3D%22%23E4E7EC%22%20stroke-width%3D%221%22%2F%3E%3Cline%20x1%3D%2240%22%20y1%3D%22280%22%20x2%3D%22420%22%20y2%3D%22280%22%20stroke%3D%22%23E4E7EC%22%20stroke-width%3D%221%22%2F%3E%3Cpath%20d%3D%22M55%20250%20C80%20240%2C100%20200%2C130%20190%20C160%20180%2C180%20160%2C210%20140%20C240%20120%2C260%20130%2C290%20110%20C320%2090%2C340%20100%2C365%2095%20C390%2090%2C400%2080%2C410%2085%22%20fill%3D%22none%22%20stroke%3D%22%237F56D9%22%20stroke-width%3D%223%22%20stroke-linecap%3D%22round%22%2F%3E%3Cpath%20d%3D%22M55%20250%20C80%20240%2C100%20200%2C130%20190%20C160%20180%2C180%20160%2C210%20140%20C240%20120%2C260%20130%2C290%20110%20C320%2090%2C340%20100%2C365%2095%20C390%2090%2C400%2080%2C410%2085%20L410%20280%20L55%20280%20Z%22%20fill%3D%22%237F56D920%22%2F%3E%3Ctext%20x%3D%2255%22%20y%3D%22300%22%20font-family%3D%22system-ui%2Csans-serif%22%20font-size%3D%2212%22%20fill%3D%22%23667085%22%3EMon%3C%2Ftext%3E%3Ctext%20x%3D%22115%22%20y%3D%22300%22%20font-family%3D%22system-ui%2Csans-serif%22%20font-size%3D%2212%22%20fill%3D%22%23667085%22%3ETue%3C%2Ftext%3E%3Ctext%20x%3D%22175%22%20y%3D%22300%22%20font-family%3D%22system-ui%2Csans-serif%22%20font-size%3D%2212%22%20fill%3D%22%23667085%22%3EWed%3C%2Ftext%3E%3Ctext%20x%3D%22233%22%20y%3D%22300%22%20font-family%3D%22system-ui%2Csans-serif%22%20font-size%3D%2212%22%20fill%3D%22%23667085%22%3EThu%3C%2Ftext%3E%3Ctext%20x%3D%22295%22%20y%3D%22300%22%20font-family%3D%22system-ui%2Csans-serif%22%20font-size%3D%2212%22%20fill%3D%22%23667085%22%3EFri%3C%2Ftext%3E%3Ctext%20x%3D%22350%22%20y%3D%22300%22%20font-family%3D%22system-ui%2Csans-serif%22%20font-size%3D%2212%22%20fill%3D%22%23667085%22%3ESat%3C%2Ftext%3E%3Ctext%20x%3D%22405%22%20y%3D%22300%22%20font-family%3D%22system-ui%2Csans-serif%22%20font-size%3D%2212%22%20fill%3D%22%23667085%22%3ESun%3C%2Ftext%3E%3Crect%20x%3D%22370%22%20y%3D%22310%22%20width%3D%22110%22%20height%3D%2232%22%20rx%3D%2216%22%20fill%3D%22white%22%20stroke%3D%22%23E4E7EC%22%20stroke-width%3D%221%22%2F%3E%3Ctext%20x%3D%22390%22%20y%3D%22330%22%20font-family%3D%22system-ui%2Csans-serif%22%20font-size%3D%2214%22%20font-weight%3D%22700%22%20fill%3D%22%23344054%22%3E1%2C000%3C%2Ftext%3E%3Ctext%20x%3D%22432%22%20y%3D%22330%22%20font-family%3D%22system-ui%2Csans-serif%22%20font-size%3D%2210%22%20fill%3D%22%23667085%22%3Eactive%3C%2Ftext%3E%3C%2Fsvg%3E",
        "alt": "Dashboard mockup preview",
        "objectFit": "contain"
      }
    },
    "carousel-caption": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "caption-title",
        "caption-text"
      ]
    },
    "caption-title": {
      "type": "Text",
      "props": {
        "tag": "h3",
        "content": "Welcome to your new dashboard",
        "align": "center",
        "variant": "inverted"
      }
    },
    "caption-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Sign in to explore changes since your last visit.",
        "align": "center",
        "variant": "inverted-secondary"
      }
    },
    "carousel-nav": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 4,
        "justify": "center",
        "align": "center"
      },
      "children": [
        "nav-arrow-left",
        "carousel-dots",
        "nav-arrow-right"
      ]
    },
    "nav-arrow-left": {
      "type": "Button",
      "props": {
        "icon": "arrow-left",
        "variant": "ghost",
        "size": "sm"
      }
    },
    "carousel-dots": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "justify": "center",
        "align": "center"
      },
      "children": [
        "dot-1",
        "dot-2",
        "dot-3",
        "dot-4",
        "dot-5"
      ]
    },
    "dot-1": {
      "type": "Badge",
      "props": {
        "variant": "dot",
        "active": false
      }
    },
    "dot-2": {
      "type": "Badge",
      "props": {
        "variant": "dot",
        "active": false
      }
    },
    "dot-3": {
      "type": "Badge",
      "props": {
        "variant": "dot",
        "active": true
      }
    },
    "dot-4": {
      "type": "Badge",
      "props": {
        "variant": "dot",
        "active": false
      }
    },
    "dot-5": {
      "type": "Badge",
      "props": {
        "variant": "dot",
        "active": false
      }
    },
    "nav-arrow-right": {
      "type": "Button",
      "props": {
        "icon": "arrow-right",
        "variant": "ghost",
        "size": "sm"
      }
    }
  }
}
