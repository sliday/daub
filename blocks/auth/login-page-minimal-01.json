{
  "root": "login-page-minimal",
  "elements": {
    "login-page-minimal": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0,
        "align": "center",
        "justify": "center",
        "container": "narrow"
      },
      "children": [
        "main-content"
      ]
    },
    "main-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 8,
        "align": "center"
      },
      "children": [
        "brand-row",
        "header",
        "form-section",
        "footer-section"
      ]
    },
    "brand-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "brand-icon",
        "brand-name"
      ]
    },
    "brand-icon": {
      "type": "Icon",
      "props": {
        "name": "layers"
      }
    },
    "brand-name": {
      "type": "Text",
      "props": {
        "tag": "h4",
        "content": "Daub"
      }
    },
    "header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3,
        "align": "center"
      },
      "children": [
        "heading",
        "subtitle"
      ]
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Log in to your account",
        "align": "center"
      }
    },
    "subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Welcome back! Please enter your details.",
        "variant": "secondary",
        "align": "center"
      }
    },
    "form-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "align": "stretch"
      },
      "children": [
        "email-input",
        "password-input",
        "signin-btn",
        "google-btn"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      }
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "••••••••",
        "type": "password"
      }
    },
    "signin-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "google-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in with Google",
        "variant": "outline",
        "size": "lg",
        "icon": "google",
        "fullWidth": true
      }
    },
    "footer-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "signup-prompt",
        "forgot-link"
      ]
    },
    "signup-prompt": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1,
        "align": "center",
        "justify": "center"
      },
      "children": [
        "signup-text",
        "signup-link"
      ]
    },
    "signup-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Don't have an account?",
        "variant": "secondary"
      }
    },
    "signup-link": {
      "type": "Button",
      "props": {
        "label": "Sign up",
        "variant": "ghost",
        "size": "sm"
      }
    },
    "forgot-link": {
      "type": "Button",
      "props": {
        "label": "Forgot password?",
        "variant": "ghost",
        "size": "sm"
      }
    }
  }
}
