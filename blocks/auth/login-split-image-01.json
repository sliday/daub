{
  "root": "login-split-image",
  "elements": {
    "login-split-image": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 0
      },
      "children": [
        "left-panel",
        "right-panel"
      ]
    },
    "left-panel": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "form-area",
        "footer-bar"
      ]
    },
    "form-area": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "justify": "center",
        "padding": 8,
        "gap": 6,
        "grow": true
      },
      "children": [
        "login-header",
        "login-form",
        "signup-prompt"
      ]
    },
    "login-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "login-title",
        "login-subtitle"
      ]
    },
    "login-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Welcome back"
      }
    },
    "login-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Welcome back! Please enter your details.",
        "variant": "secondary"
      }
    },
    "login-form": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "email-field",
        "password-field",
        "options-row",
        "signin-btn",
        "google-btn"
      ]
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      }
    },
    "password-field": {
      "type": "Field",
      "props": {
        "label": "Password"
      },
      "children": [
        "password-input"
      ]
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "••••••••",
        "type": "password"
      }
    },
    "options-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "justify": "between",
        "align": "center"
      },
      "children": [
        "remember-check",
        "forgot-link"
      ]
    },
    "remember-check": {
      "type": "Checkbox",
      "props": {
        "label": "Remember for 30 days",
        "checked": false
      }
    },
    "forgot-link": {
      "type": "Link",
      "props": {
        "label": "Forgot password?"
      }
    },
    "signin-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "google-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in with Google",
        "variant": "outline",
        "size": "lg",
        "fullWidth": true,
        "icon": "google"
      }
    },
    "signup-prompt": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1
      },
      "children": [
        "signup-text",
        "signup-link"
      ]
    },
    "signup-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Don't have an account?",
        "variant": "secondary"
      }
    },
    "signup-link": {
      "type": "Link",
      "props": {
        "label": "Sign up"
      }
    },
    "footer-bar": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "padding": [
          2,
          4
        ]
      },
      "children": [
        "footer-text"
      ]
    },
    "footer-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "© Daub 2026",
        "variant": "secondary"
      }
    },
    "right-panel": {
      "type": "Image",
      "props": {
        "src": "data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22720%22%20height%3D%22960%22%20viewBox%3D%220%200%20720%20960%22%3E%3Cdefs%3E%3ClinearGradient%20id%3D%22bg%22%20x1%3D%220%22%20y1%3D%220%22%20x2%3D%221%22%20y2%3D%221%22%3E%3Cstop%20offset%3D%220%25%22%20stop-color%3D%22%237F56D9%22%2F%3E%3Cstop%20offset%3D%22100%25%22%20stop-color%3D%22%239E77ED%22%2F%3E%3C%2FlinearGradient%3E%3C%2Fdefs%3E%3Crect%20width%3D%22720%22%20height%3D%22960%22%20fill%3D%22url(%23bg)%22%2F%3E%3Ccircle%20cx%3D%22200%22%20cy%3D%22300%22%20r%3D%22180%22%20fill%3D%22white%22%20opacity%3D%220.1%22%2F%3E%3Ccircle%20cx%3D%22350%22%20cy%3D%22250%22%20r%3D%22220%22%20fill%3D%22white%22%20opacity%3D%220.1%22%2F%3E%3Ccircle%20cx%3D%22550%22%20cy%3D%22500%22%20r%3D%22260%22%20fill%3D%22white%22%20opacity%3D%220.1%22%2F%3E%3Ccircle%20cx%3D%22150%22%20cy%3D%22700%22%20r%3D%22200%22%20fill%3D%22white%22%20opacity%3D%220.1%22%2F%3E%3Ccircle%20cx%3D%22400%22%20cy%3D%22750%22%20r%3D%22160%22%20fill%3D%22white%22%20opacity%3D%220.1%22%2F%3E%3Ccircle%20cx%3D%22100%22%20cy%3D%22150%22%20r%3D%226%22%20fill%3D%22white%22%20opacity%3D%220.5%22%2F%3E%3Ccircle%20cx%3D%22600%22%20cy%3D%22200%22%20r%3D%224%22%20fill%3D%22white%22%20opacity%3D%220.4%22%2F%3E%3Ccircle%20cx%3D%22500%22%20cy%3D%22100%22%20r%3D%225%22%20fill%3D%22white%22%20opacity%3D%220.6%22%2F%3E%3Ccircle%20cx%3D%2280%22%20cy%3D%22500%22%20r%3D%223%22%20fill%3D%22white%22%20opacity%3D%220.5%22%2F%3E%3Ccircle%20cx%3D%22650%22%20cy%3D%22650%22%20r%3D%225%22%20fill%3D%22white%22%20opacity%3D%220.3%22%2F%3E%3Ccircle%20cx%3D%22300%22%20cy%3D%22850%22%20r%3D%224%22%20fill%3D%22white%22%20opacity%3D%220.45%22%2F%3E%3Ccircle%20cx%3D%22680%22%20cy%3D%22400%22%20r%3D%226%22%20fill%3D%22white%22%20opacity%3D%220.35%22%2F%3E%3Ccircle%20cx%3D%22250%22%20cy%3D%22550%22%20r%3D%223%22%20fill%3D%22white%22%20opacity%3D%220.55%22%2F%3E%3C%2Fsvg%3E",
        "alt": "Login hero image",
        "objectFit": "cover",
        "fullHeight": true
      }
    }
  }
}
