{
  "root": "login-split-image",
  "elements": {
    "login-split-image": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 0
      },
      "children": [
        "left-panel",
        "right-panel"
      ]
    },
    "left-panel": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "form-area",
        "footer-bar"
      ]
    },
    "form-area": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "justify": "center",
        "padding": 8,
        "gap": 6,
        "grow": true
      },
      "children": [
        "login-header",
        "login-form",
        "signup-prompt"
      ]
    },
    "login-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "login-title",
        "login-subtitle"
      ]
    },
    "login-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Welcome back"
      }
    },
    "login-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Welcome back! Please enter your details.",
        "variant": "secondary"
      }
    },
    "login-form": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "email-field",
        "password-field",
        "options-row",
        "signin-btn",
        "google-btn"
      ]
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      }
    },
    "password-field": {
      "type": "Field",
      "props": {
        "label": "Password"
      },
      "children": [
        "password-input"
      ]
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "••••••••",
        "type": "password"
      }
    },
    "options-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "justify": "between",
        "align": "center"
      },
      "children": [
        "remember-check",
        "forgot-link"
      ]
    },
    "remember-check": {
      "type": "Checkbox",
      "props": {
        "label": "Remember for 30 days",
        "checked": false
      }
    },
    "forgot-link": {
      "type": "Link",
      "props": {
        "label": "Forgot password?"
      }
    },
    "signin-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "google-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in with Google",
        "variant": "outline",
        "size": "lg",
        "fullWidth": true,
        "icon": "google"
      }
    },
    "signup-prompt": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1
      },
      "children": [
        "signup-text",
        "signup-link"
      ]
    },
    "signup-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Don't have an account?",
        "variant": "secondary"
      }
    },
    "signup-link": {
      "type": "Link",
      "props": {
        "label": "Sign up"
      }
    },
    "footer-bar": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "padding": [
          2,
          4
        ]
      },
      "children": [
        "footer-text"
      ]
    },
    "footer-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "© Daub 2026",
        "variant": "secondary"
      }
    },
    "right-panel": {
      "type": "Surface",
      "props": {
        "variant": "brand",
        "padding": 8
      },
      "children": ["right-inner"]
    },
    "right-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "justify": "center",
        "align": "center"
      },
      "children": ["right-icon", "right-heading", "right-text"]
    },
    "right-icon": {
      "type": "Icon",
      "props": {
        "name": "shield-check",
        "size": "lg"
      }
    },
    "right-heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Secure by design",
        "align": "center",
        "variant": "inverted"
      }
    },
    "right-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Your data is protected with enterprise-grade encryption and compliance certifications.",
        "align": "center",
        "variant": "inverted-secondary"
      }
    }
  }
}
