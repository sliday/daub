{
  "root": "login-page-illustration",
  "elements": {
    "login-page-illustration": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0,
        "align": "center",
        "justify": "center",
        "container": "narrow"
      },
      "children": [
        "main-content"
      ]
    },
    "main-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "align": "center"
      },
      "children": [
        "header",
        "form-section",
        "signup-prompt"
      ]
    },
    "header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "align": "center"
      },
      "children": [
        "illustration",
        "heading",
        "subtitle"
      ]
    },
    "illustration": {
      "type": "Image",
      "props": {
        "src": "data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22120%22%20height%3D%22120%22%20viewBox%3D%220%200%20120%20120%22%3E%3Ccircle%20cx%3D%2260%22%20cy%3D%2262%22%20r%3D%2236%22%20fill%3D%22%237F56D910%22%2F%3E%3Cellipse%20cx%3D%2260%22%20cy%3D%2268%22%20rx%3D%2242%22%20ry%3D%2226%22%20fill%3D%22%23E4E7EC%22%2F%3E%3Cellipse%20cx%3D%2238%22%20cy%3D%2258%22%20rx%3D%2220%22%20ry%3D%2218%22%20fill%3D%22%23E4E7EC%22%2F%3E%3Cellipse%20cx%3D%2278%22%20cy%3D%2256%22%20rx%3D%2222%22%20ry%3D%2220%22%20fill%3D%22%23E4E7EC%22%2F%3E%3Cellipse%20cx%3D%2260%22%20cy%3D%2250%22%20rx%3D%2224%22%20ry%3D%2218%22%20fill%3D%22%23E4E7EC%22%2F%3E%3Ccircle%20cx%3D%2260%22%20cy%3D%2252%22%20r%3D%2212%22%20fill%3D%22%237F56D9%22%2F%3E%3Ccircle%20cx%3D%2260%22%20cy%3D%2252%22%20r%3D%226%22%20fill%3D%22%23FFFFFF%22%2F%3E%3Ccircle%20cx%3D%2260%22%20cy%3D%2252%22%20r%3D%223%22%20fill%3D%22%237F56D9%22%2F%3E%3Crect%20x%3D%2258%22%20y%3D%2264%22%20width%3D%224%22%20height%3D%2220%22%20rx%3D%222%22%20fill%3D%22%237F56D9%22%2F%3E%3Crect%20x%3D%2262%22%20y%3D%2276%22%20width%3D%2210%22%20height%3D%224%22%20rx%3D%222%22%20fill%3D%22%237F56D9%22%2F%3E%3C%2Fsvg%3E",
        "alt": "Decorative illustration",
        "aspectRatio": "1/1",
        "width": 120
      }
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Log in to your account",
        "align": "center"
      }
    },
    "subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Welcome back! Please enter your details.",
        "variant": "secondary",
        "align": "center"
      }
    },
    "form-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "align": "stretch"
      },
      "children": [
        "email-field",
        "password-field",
        "options-row",
        "signin-btn",
        "google-btn"
      ]
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      }
    },
    "password-field": {
      "type": "Field",
      "props": {
        "label": "Password"
      },
      "children": [
        "password-input"
      ]
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "••••••••",
        "type": "password"
      }
    },
    "options-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 0,
        "align": "center",
        "justify": "between"
      },
      "children": [
        "remember-check",
        "forgot-link"
      ]
    },
    "remember-check": {
      "type": "Checkbox",
      "props": {
        "label": "Remember for 30 days",
        "checked": false
      }
    },
    "forgot-link": {
      "type": "Link",
      "props": {
        "label": "Forgot password?"
      }
    },
    "signin-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "google-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in with Google",
        "variant": "outline",
        "size": "lg",
        "icon": "google",
        "fullWidth": true
      }
    },
    "signup-prompt": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1,
        "align": "center",
        "justify": "center"
      },
      "children": [
        "signup-text",
        "signup-link"
      ]
    },
    "signup-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Don't have an account?",
        "variant": "secondary"
      }
    },
    "signup-link": {
      "type": "Link",
      "props": {
        "label": "Sign up"
      }
    }
  }
}
