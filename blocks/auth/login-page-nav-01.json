{
  "root": "login-page-nav-01",
  "elements": {
    "login-page-nav-01": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "nav-bar",
        "main-content"
      ]
    },
    "nav-bar": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 0,
        "justify": "between",
        "align": "center",
        "padding": 4
      },
      "children": [
        "nav-brand",
        "nav-signup"
      ]
    },
    "nav-brand": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "nav-logo",
        "nav-title"
      ]
    },
    "nav-logo": {
      "type": "Icon",
      "props": {
        "name": "layers"
      }
    },
    "nav-title": {
      "type": "Text",
      "props": {
        "tag": "h4",
        "content": "Daub"
      }
    },
    "nav-signup": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1,
        "align": "center"
      },
      "children": [
        "nav-signup-text",
        "nav-signup-link"
      ]
    },
    "nav-signup-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Don't have an account?",
        "variant": "secondary"
      }
    },
    "nav-signup-link": {
      "type": "Link",
      "props": {
        "label": "Sign up"
      }
    },
    "main-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "align": "center",
        "justify": "center",
        "container": "narrow",
        "padding": [
          8,
          0
        ]
      },
      "children": [
        "header",
        "form-group",
        "sso-btn"
      ]
    },
    "header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "header-title",
        "header-subtitle"
      ]
    },
    "header-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Log in to your account"
      }
    },
    "header-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Welcome back! Please enter your details.",
        "variant": "secondary"
      }
    },
    "form-group": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "align": "stretch"
      },
      "children": [
        "email-field",
        "password-field",
        "options-row",
        "signin-btn",
        "google-btn"
      ]
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      }
    },
    "password-field": {
      "type": "Field",
      "props": {
        "label": "Password"
      },
      "children": [
        "password-input"
      ]
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "••••••••",
        "type": "password"
      }
    },
    "options-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 0,
        "justify": "between",
        "align": "center"
      },
      "children": [
        "remember-check",
        "forgot-link"
      ]
    },
    "remember-check": {
      "type": "Checkbox",
      "props": {
        "label": "Remember for 30 days",
        "checked": false
      }
    },
    "forgot-link": {
      "type": "Link",
      "props": {
        "label": "Forgot password?"
      }
    },
    "signin-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "google-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in with Google",
        "variant": "outline",
        "size": "lg",
        "fullWidth": true,
        "icon": "google"
      }
    },
    "sso-btn": {
      "type": "Button",
      "props": {
        "label": "Continue with SAML SSO",
        "variant": "ghost",
        "size": "sm"
      }
    }
  }
}
