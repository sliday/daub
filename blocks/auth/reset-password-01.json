{
  "root": "reset-password",
  "elements": {
    "reset-password": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0,
        "align": "center",
        "justify": "center",
        "container": "narrow"
      },
      "children": [
        "reset-card"
      ]
    },
    "reset-card": {
      "type": "Card",
      "props": {
        "title": "Set a new password",
        "description": "Your new password must be at least 8 characters and include a number and a special character."
      },
      "children": [
        "card-body"
      ]
    },
    "card-body": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "new-password-field",
        "strength-group",
        "confirm-field",
        "reset-btn",
        "divider",
        "back-row"
      ]
    },
    "new-password-field": {
      "type": "Field",
      "props": {
        "label": "New Password"
      },
      "children": [
        "new-password-input"
      ]
    },
    "new-password-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your new password",
        "type": "password"
      }
    },
    "strength-group": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "strength-bar",
        "strength-label"
      ]
    },
    "strength-bar": {
      "type": "Progress",
      "props": {
        "value": 60
      }
    },
    "strength-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Password strength: Medium",
        "variant": "muted"
      }
    },
    "confirm-field": {
      "type": "Field",
      "props": {
        "label": "Confirm New Password"
      },
      "children": [
        "confirm-input"
      ]
    },
    "confirm-input": {
      "type": "Input",
      "props": {
        "placeholder": "Re-enter your new password",
        "type": "password"
      }
    },
    "reset-btn": {
      "type": "Button",
      "props": {
        "label": "Reset Password",
        "variant": "primary",
        "size": "lg"
      }
    },
    "divider": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "back-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1,
        "align": "center",
        "justify": "center"
      },
      "children": [
        "back-text",
        "back-link"
      ]
    },
    "back-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Remembered your password?",
        "variant": "muted"
      }
    },
    "back-link": {
      "type": "Link",
      "props": {
        "label": "Back to sign in"
      }
    }
  }
}
