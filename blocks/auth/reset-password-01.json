{
  "root": "reset-password",
  "elements": {
    "reset-password": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 0,
      "align": "center",
      "justify": "center",
      "container": "narrow",
      "children": ["reset-card"]
    },
    "reset-card": {
      "type": "Card",
      "title": "Set a new password",
      "description": "Your new password must be at least 8 characters and include a number and a special character.",
      "children": ["card-body"]
    },
    "card-body": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 4,
      "children": ["new-password-field", "strength-group", "confirm-field", "reset-btn", "divider", "back-row"]
    },
    "new-password-field": {
      "type": "Field",
      "label": "New Password",
      "children": ["new-password-input"]
    },
    "new-password-input": {
      "type": "Input",
      "type": "password",
      "placeholder": "Enter your new password"
    },
    "strength-group": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 1,
      "children": ["strength-bar", "strength-label"]
    },
    "strength-bar": {
      "type": "Progress",
      "value": 60
    },
    "strength-label": {
      "type": "Text",
      "tag": "p",
      "content": "Password strength: Medium",
      "variant": "muted"
    },
    "confirm-field": {
      "type": "Field",
      "label": "Confirm New Password",
      "children": ["confirm-input"]
    },
    "confirm-input": {
      "type": "Input",
      "type": "password",
      "placeholder": "Re-enter your new password"
    },
    "reset-btn": {
      "type": "Button",
      "label": "Reset Password",
      "variant": "primary",
      "size": "lg"
    },
    "divider": {
      "type": "Separator",
      "orientation": "horizontal"
    },
    "back-row": {
      "type": "Stack",
      "direction": "horizontal",
      "gap": 1,
      "align": "center",
      "justify": "center",
      "children": ["back-text", "back-link"]
    },
    "back-text": {
      "type": "Text",
      "tag": "p",
      "content": "Remembered your password?",
      "variant": "muted"
    },
    "back-link": {
      "type": "Button",
      "label": "Back to sign in",
      "variant": "ghost",
      "size": "sm"
    }
  }
}