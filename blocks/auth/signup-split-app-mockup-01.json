{
  "root": "signup-split-app-mockup",
  "elements": {
    "signup-split-app-mockup": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 0
      },
      "children": [
        "form-panel",
        "app-mockup-panel"
      ]
    },
    "form-panel": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "nav-bar",
        "form-container",
        "form-footer"
      ]
    },
    "nav-bar": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center",
        "padding": [
          3,
          4
        ]
      },
      "children": [
        "nav-logo"
      ]
    },
    "nav-logo": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "logo-icon",
        "logo-text"
      ]
    },
    "logo-icon": {
      "type": "Icon",
      "props": {
        "name": "layers",
        "size": "md"
      }
    },
    "logo-text": {
      "type": "Text",
      "props": {
        "tag": "h4",
        "content": "Daub"
      }
    },
    "form-container": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "justify": "center",
        "padding": [
          4,
          8
        ]
      },
      "children": [
        "form-header",
        "form-fields",
        "form-login"
      ]
    },
    "form-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "form-title",
        "form-subtitle"
      ]
    },
    "form-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Sign up"
      }
    },
    "form-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Start your 30-day free trial.",
        "variant": "secondary"
      }
    },
    "form-fields": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "name-field",
        "email-field",
        "password-field",
        "signup-btn",
        "google-btn"
      ]
    },
    "name-field": {
      "type": "Field",
      "props": {
        "label": "Name*"
      },
      "children": [
        "name-input"
      ]
    },
    "name-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your name",
        "type": "text"
      }
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email*"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      }
    },
    "password-field": {
      "type": "Field",
      "props": {
        "label": "Password*",
        "hint": "Must be at least 8 characters."
      },
      "children": [
        "password-input"
      ]
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "Create a password",
        "type": "password"
      }
    },
    "signup-btn": {
      "type": "Button",
      "props": {
        "label": "Get started",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "google-btn": {
      "type": "Button",
      "props": {
        "label": "Sign up with Google",
        "variant": "outline",
        "size": "lg",
        "icon": "google",
        "fullWidth": true
      }
    },
    "form-login": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1,
        "align": "center"
      },
      "children": [
        "login-text",
        "login-link"
      ]
    },
    "login-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Already have an account?",
        "variant": "secondary"
      }
    },
    "login-link": {
      "type": "Link",
      "props": {
        "label": "Log in"
      }
    },
    "form-footer": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "padding": [
          2,
          4
        ]
      },
      "children": [
        "footer-text"
      ]
    },
    "footer-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "© Daub 2026",
        "variant": "secondary"
      }
    },
    "app-mockup-panel": {
      "type": "Surface",
      "props": {
        "variant": "sunken",
        "padding": 6
      },
      "children": [
        "app-content"
      ]
    },
    "app-content": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 6, "justify": "center" },
      "children": ["app-header", "app-stats", "app-features"]
    },
    "app-header": {
      "type": "Text",
      "props": { "tag": "h3", "content": "Your analytics at a glance", "weight": "semibold" }
    },
    "app-stats": {
      "type": "Grid",
      "props": { "columns": 2, "gap": 4 },
      "children": ["as-1", "as-2", "as-3", "as-4"]
    },
    "as-1": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 1 },
      "children": ["as-1-v", "as-1-l"]
    },
    "as-1-v": { "type": "Text", "props": { "tag": "h3", "content": "2,420" } },
    "as-1-l": { "type": "Text", "props": { "tag": "span", "content": "Active users", "variant": "secondary" } },
    "as-2": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 1 },
      "children": ["as-2-v", "as-2-l"]
    },
    "as-2-v": { "type": "Text", "props": { "tag": "h3", "content": "$45.2k" } },
    "as-2-l": { "type": "Text", "props": { "tag": "span", "content": "Revenue", "variant": "secondary" } },
    "as-3": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 1 },
      "children": ["as-3-v", "as-3-l"]
    },
    "as-3-v": { "type": "Text", "props": { "tag": "h3", "content": "+18%" } },
    "as-3-l": { "type": "Text", "props": { "tag": "span", "content": "Growth", "variant": "secondary" } },
    "as-4": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 1 },
      "children": ["as-4-v", "as-4-l"]
    },
    "as-4-v": { "type": "Text", "props": { "tag": "h3", "content": "99.9%" } },
    "as-4-l": { "type": "Text", "props": { "tag": "span", "content": "Uptime", "variant": "secondary" } },
    "app-features": {
      "type": "List",
      "props": {
        "items": [
          { "primary": "Real-time analytics dashboard", "icon": "bar-chart-2" },
          { "primary": "Team collaboration tools", "icon": "users" },
          { "primary": "Automated reporting", "icon": "file-text" }
        ]
      }
    }
  }
}
