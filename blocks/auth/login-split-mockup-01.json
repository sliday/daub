{
  "root": "login-split-mockup",
  "elements": {
    "login-split-mockup": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 0
      },
      "children": [
        "left-panel",
        "right-panel"
      ]
    },
    "left-panel": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "form-area",
        "footer-bar"
      ]
    },
    "form-area": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "justify": "center",
        "padding": 8,
        "gap": 6,
        "grow": true
      },
      "children": [
        "login-header",
        "login-form",
        "signup-prompt"
      ]
    },
    "login-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "login-title",
        "login-subtitle"
      ]
    },
    "login-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Welcome back"
      }
    },
    "login-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Welcome back! Please enter your details.",
        "variant": "secondary"
      }
    },
    "login-form": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "email-field",
        "password-field",
        "options-row",
        "signin-btn",
        "google-btn"
      ]
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      }
    },
    "password-field": {
      "type": "Field",
      "props": {
        "label": "Password"
      },
      "children": [
        "password-input"
      ]
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "••••••••",
        "type": "password"
      }
    },
    "options-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "justify": "between",
        "align": "center"
      },
      "children": [
        "remember-check",
        "forgot-link"
      ]
    },
    "remember-check": {
      "type": "Checkbox",
      "props": {
        "label": "Remember for 30 days",
        "checked": false
      }
    },
    "forgot-link": {
      "type": "Link",
      "props": {
        "label": "Forgot password?"
      }
    },
    "signin-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "google-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in with Google",
        "variant": "outline",
        "size": "lg",
        "fullWidth": true,
        "icon": "google"
      }
    },
    "signup-prompt": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1
      },
      "children": [
        "signup-text",
        "signup-link"
      ]
    },
    "signup-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Don't have an account?",
        "variant": "secondary"
      }
    },
    "signup-link": {
      "type": "Link",
      "props": {
        "label": "Sign up"
      }
    },
    "footer-bar": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "padding": [
          2,
          4
        ]
      },
      "children": [
        "footer-text"
      ]
    },
    "footer-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "© Daub 2026",
        "variant": "secondary"
      }
    },
    "right-panel": {
      "type": "Surface",
      "props": {
        "variant": "sunken",
        "padding": 8
      },
      "children": [
        "mockup-container"
      ]
    },
    "mockup-container": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "justify": "center",
        "align": "center",
        "fullHeight": true,
        "gap": 4
      },
      "children": [
        "mockup-image"
      ]
    },
    "mockup-image": {
      "type": "Surface",
      "props": {
        "variant": "card",
        "padding": 5
      },
      "children": ["mi-content"]
    },
    "mi-content": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 5 },
      "children": ["mi-header", "mi-stats"]
    },
    "mi-header": {
      "type": "Text",
      "props": { "tag": "h4", "content": "Dashboard Overview", "weight": "semibold" }
    },
    "mi-stats": {
      "type": "Grid",
      "props": { "columns": 2, "gap": 4 },
      "children": ["mi-s1", "mi-s2", "mi-s3", "mi-s4"]
    },
    "mi-s1": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 1 },
      "children": ["mi-s1-v", "mi-s1-l"]
    },
    "mi-s1-v": { "type": "Text", "props": { "tag": "h3", "content": "2,420" } },
    "mi-s1-l": { "type": "Text", "props": { "tag": "span", "content": "Active users", "variant": "secondary" } },
    "mi-s2": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 1 },
      "children": ["mi-s2-v", "mi-s2-l"]
    },
    "mi-s2-v": { "type": "Text", "props": { "tag": "h3", "content": "$45.2k" } },
    "mi-s2-l": { "type": "Text", "props": { "tag": "span", "content": "Revenue", "variant": "secondary" } },
    "mi-s3": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 1 },
      "children": ["mi-s3-v", "mi-s3-l"]
    },
    "mi-s3-v": { "type": "Text", "props": { "tag": "h3", "content": "+18%" } },
    "mi-s3-l": { "type": "Text", "props": { "tag": "span", "content": "Growth", "variant": "secondary" } },
    "mi-s4": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 1 },
      "children": ["mi-s4-v", "mi-s4-l"]
    },
    "mi-s4-v": { "type": "Text", "props": { "tag": "h3", "content": "99.9%" } },
    "mi-s4-l": { "type": "Text", "props": { "tag": "span", "content": "Uptime", "variant": "secondary" } }
  }
}
