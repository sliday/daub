{
  "root": "login-split-mockup-quote",
  "elements": {
    "login-split-mockup-quote": {
      "type": "Grid",
      "props": { "columns": 2, "gap": 0 },
      "children": ["form-panel", "showcase-panel"]
    },

    "form-panel": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 0 },
      "children": ["form-container", "form-footer"]
    },
    "form-container": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 6, "justify": "center", "padding": 8 },
      "children": ["form-header", "form-fields", "form-signup"]
    },
    "form-header": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 2 },
      "children": ["form-title", "form-subtitle"]
    },
    "form-title": {
      "type": "Text",
      "props": { "tag": "h2", "content": "Welcome back" }
    },
    "form-subtitle": {
      "type": "Text",
      "props": { "tag": "p", "content": "Welcome back! Please enter your details.", "variant": "secondary" }
    },
    "form-fields": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 4 },
      "children": ["email-field", "password-field", "options-row", "signin-btn", "google-btn"]
    },
    "email-field": {
      "type": "Field",
      "props": { "label": "Email" },
      "children": ["email-input"]
    },
    "email-input": {
      "type": "Input",
      "props": { "placeholder": "Enter your email", "type": "email" }
    },
    "password-field": {
      "type": "Field",
      "props": { "label": "Password" },
      "children": ["password-input"]
    },
    "password-input": {
      "type": "Input",
      "props": { "placeholder": "••••••••", "type": "password" }
    },
    "options-row": {
      "type": "Stack",
      "props": { "direction": "horizontal", "gap": 0, "align": "center", "justify": "between" },
      "children": ["remember-check", "forgot-link"]
    },
    "remember-check": {
      "type": "Checkbox",
      "props": { "label": "Remember for 30 days", "checked": false }
    },
    "forgot-link": {
      "type": "Button",
      "props": { "label": "Forgot password?", "variant": "ghost", "size": "sm" }
    },
    "signin-btn": {
      "type": "Button",
      "props": { "label": "Sign in", "variant": "primary", "size": "lg", "fullWidth": true }
    },
    "google-btn": {
      "type": "Button",
      "props": { "label": "Sign in with Google", "variant": "outline", "size": "lg", "icon": "google", "fullWidth": true }
    },
    "form-signup": {
      "type": "Stack",
      "props": { "direction": "horizontal", "gap": 1, "align": "center" },
      "children": ["signup-text", "signup-link"]
    },
    "signup-text": {
      "type": "Text",
      "props": { "tag": "span", "content": "Don't have an account?", "variant": "secondary" }
    },
    "signup-link": {
      "type": "Button",
      "props": { "label": "Sign up", "variant": "ghost", "size": "sm" }
    },
    "form-footer": {
      "type": "Stack",
      "props": { "direction": "horizontal", "padding": [2, 4] },
      "children": ["footer-text"]
    },
    "footer-text": {
      "type": "Text",
      "props": { "tag": "span", "content": "© Daub 2026", "variant": "secondary" }
    },

    "showcase-panel": {
      "type": "Surface",
      "props": { "variant": "sunken", "padding": 6 },
      "children": ["showcase-inner"]
    },
    "showcase-inner": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 6, "justify": "center", "align": "center" },
      "children": ["mockup-image", "showcase-quote"]
    },
    "mockup-image": {
      "type": "Image",
      "props": { "src": "", "alt": "Dashboard mockup preview", "objectFit": "contain" }
    },
    "showcase-quote": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 4, "align": "center" },
      "children": ["quote-text", "quote-author"]
    },
    "quote-text": {
      "type": "Text",
      "props": { "tag": "p", "content": "\"We've been using Daub to kick start every new project and can't imagine working without it.\"", "variant": "secondary", "align": "center" }
    },
    "quote-author": {
      "type": "Stack",
      "props": { "direction": "horizontal", "gap": 3, "align": "center" },
      "children": ["author-avatar", "author-info"]
    },
    "author-avatar": {
      "type": "Avatar",
      "props": { "initials": "KW", "size": "sm" }
    },
    "author-info": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 0 },
      "children": ["author-name", "author-role"]
    },
    "author-name": {
      "type": "Text",
      "props": { "tag": "span", "content": "Kelly Williams" }
    },
    "author-role": {
      "type": "Text",
      "props": { "tag": "span", "content": "Head of Design, Layers", "variant": "secondary" }
    }
  }
}
