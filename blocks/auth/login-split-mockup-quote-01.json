{
  "root": "login-split-mockup-quote",
  "elements": {
    "login-split-mockup-quote": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 0
      },
      "children": [
        "form-panel",
        "showcase-panel"
      ]
    },
    "form-panel": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "form-container",
        "form-footer"
      ]
    },
    "form-container": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "justify": "center",
        "padding": 8
      },
      "children": [
        "form-header",
        "form-fields",
        "form-signup"
      ]
    },
    "form-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "form-title",
        "form-subtitle"
      ]
    },
    "form-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Welcome back"
      }
    },
    "form-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Welcome back! Please enter your details.",
        "variant": "secondary"
      }
    },
    "form-fields": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "email-field",
        "password-field",
        "options-row",
        "signin-btn",
        "google-btn"
      ]
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      }
    },
    "password-field": {
      "type": "Field",
      "props": {
        "label": "Password"
      },
      "children": [
        "password-input"
      ]
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "••••••••",
        "type": "password"
      }
    },
    "options-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 0,
        "align": "center",
        "justify": "between"
      },
      "children": [
        "remember-check",
        "forgot-link"
      ]
    },
    "remember-check": {
      "type": "Checkbox",
      "props": {
        "label": "Remember for 30 days",
        "checked": false
      }
    },
    "forgot-link": {
      "type": "Link",
      "props": {
        "label": "Forgot password?"
      }
    },
    "signin-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "google-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in with Google",
        "variant": "outline",
        "size": "lg",
        "icon": "google",
        "fullWidth": true
      }
    },
    "form-signup": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1,
        "align": "center"
      },
      "children": [
        "signup-text",
        "signup-link"
      ]
    },
    "signup-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Don't have an account?",
        "variant": "secondary"
      }
    },
    "signup-link": {
      "type": "Link",
      "props": {
        "label": "Sign up"
      }
    },
    "form-footer": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "padding": [
          2,
          4
        ]
      },
      "children": [
        "footer-text"
      ]
    },
    "footer-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "© Daub 2026",
        "variant": "secondary"
      }
    },
    "showcase-panel": {
      "type": "Surface",
      "props": {
        "variant": "sunken",
        "padding": 6
      },
      "children": [
        "showcase-inner"
      ]
    },
    "showcase-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "justify": "center",
        "align": "center"
      },
      "children": [
        "mockup-image",
        "showcase-quote"
      ]
    },
    "mockup-image": {
      "type": "Image",
      "props": {
        "src": "data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22600%22%20height%3D%22400%22%20viewBox%3D%220%200%20600%20400%22%3E%3Crect%20width%3D%22600%22%20height%3D%22400%22%20rx%3D%2212%22%20fill%3D%22%23F2F4F7%22%2F%3E%3Crect%20x%3D%220%22%20y%3D%220%22%20width%3D%22600%22%20height%3D%2248%22%20rx%3D%2212%22%20fill%3D%22%23E4E7EC%22%2F%3E%3Crect%20x%3D%220%22%20y%3D%2236%22%20width%3D%22600%22%20height%3D%2212%22%20fill%3D%22%23E4E7EC%22%2F%3E%3Crect%20x%3D%220%22%20y%3D%2248%22%20width%3D%22140%22%20height%3D%22352%22%20fill%3D%22%23E4E7EC%22%2F%3E%3Crect%20x%3D%2216%22%20y%3D%2264%22%20width%3D%22108%22%20height%3D%2210%22%20rx%3D%223%22%20fill%3D%22%23C0C5CE%22%2F%3E%3Crect%20x%3D%2216%22%20y%3D%2284%22%20width%3D%2290%22%20height%3D%228%22%20rx%3D%223%22%20fill%3D%22%23C0C5CE%22%2F%3E%3Crect%20x%3D%2216%22%20y%3D%22100%22%20width%3D%2298%22%20height%3D%228%22%20rx%3D%223%22%20fill%3D%22%23C0C5CE%22%2F%3E%3Crect%20x%3D%2216%22%20y%3D%22116%22%20width%3D%2280%22%20height%3D%228%22%20rx%3D%223%22%20fill%3D%22%23C0C5CE%22%2F%3E%3Crect%20x%3D%22164%22%20y%3D%2272%22%20width%3D%22196%22%20height%3D%2290%22%20rx%3D%2210%22%20fill%3D%22white%22%2F%3E%3Crect%20x%3D%22180%22%20y%3D%2288%22%20width%3D%2260%22%20height%3D%228%22%20rx%3D%223%22%20fill%3D%22%23C0C5CE%22%2F%3E%3Crect%20x%3D%22180%22%20y%3D%22104%22%20width%3D%2290%22%20height%3D%2216%22%20rx%3D%223%22%20fill%3D%22%237F56D9%22%20opacity%3D%220.2%22%2F%3E%3Crect%20x%3D%22180%22%20y%3D%22128%22%20width%3D%2240%22%20height%3D%228%22%20rx%3D%223%22%20fill%3D%22%23C0C5CE%22%2F%3E%3Crect%20x%3D%22384%22%20y%3D%2272%22%20width%3D%22196%22%20height%3D%2290%22%20rx%3D%2210%22%20fill%3D%22white%22%2F%3E%3Crect%20x%3D%22400%22%20y%3D%2288%22%20width%3D%2260%22%20height%3D%228%22%20rx%3D%223%22%20fill%3D%22%23C0C5CE%22%2F%3E%3Crect%20x%3D%22400%22%20y%3D%22104%22%20width%3D%2290%22%20height%3D%2216%22%20rx%3D%223%22%20fill%3D%22%237F56D9%22%20opacity%3D%220.2%22%2F%3E%3Crect%20x%3D%22400%22%20y%3D%22128%22%20width%3D%2240%22%20height%3D%228%22%20rx%3D%223%22%20fill%3D%22%23C0C5CE%22%2F%3E%3Crect%20x%3D%22164%22%20y%3D%22186%22%20width%3D%22416%22%20height%3D%22190%22%20rx%3D%2210%22%20fill%3D%22white%22%2F%3E%3Crect%20x%3D%22180%22%20y%3D%22202%22%20width%3D%2280%22%20height%3D%228%22%20rx%3D%223%22%20fill%3D%22%23C0C5CE%22%2F%3E%3Cpath%20d%3D%22M190%20340%20L230%20310%20L270%20320%20L310%20280%20L350%20290%20L390%20250%20L430%20260%20L470%20230%20L510%20240%20L550%20220%22%20fill%3D%22none%22%20stroke%3D%22%237F56D9%22%20stroke-width%3D%222.5%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3Cpath%20d%3D%22M190%20340%20L230%20310%20L270%20320%20L310%20280%20L350%20290%20L390%20250%20L430%20260%20L470%20230%20L510%20240%20L550%20220%20L550%20350%20L190%20350Z%22%20fill%3D%22%237F56D9%22%20opacity%3D%220.08%22%2F%3E%3C%2Fsvg%3E",
        "alt": "Dashboard mockup preview",
        "objectFit": "contain"
      }
    },
    "showcase-quote": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "align": "center"
      },
      "children": [
        "quote-text",
        "quote-author"
      ]
    },
    "quote-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "\"We've been using Daub to kick start every new project and can't imagine working without it.\"",
        "variant": "secondary",
        "align": "center"
      }
    },
    "quote-author": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3,
        "align": "center"
      },
      "children": [
        "author-avatar",
        "author-info"
      ]
    },
    "author-avatar": {
      "type": "Avatar",
      "props": {
        "initials": "KW",
        "size": "sm"
      }
    },
    "author-info": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "author-name",
        "author-role"
      ]
    },
    "author-name": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Kelly Williams"
      }
    },
    "author-role": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Head of Design, Layers",
        "variant": "secondary"
      }
    }
  }
}
