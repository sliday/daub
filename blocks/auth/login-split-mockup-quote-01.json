{
  "root": "login-split-mockup-quote",
  "elements": {
    "login-split-mockup-quote": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 0
      },
      "children": [
        "form-panel",
        "showcase-panel"
      ]
    },
    "form-panel": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "form-container",
        "form-footer"
      ]
    },
    "form-container": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "justify": "center",
        "padding": 8
      },
      "children": [
        "form-header",
        "form-fields",
        "form-signup"
      ]
    },
    "form-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "form-title",
        "form-subtitle"
      ]
    },
    "form-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Welcome back"
      }
    },
    "form-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Welcome back! Please enter your details.",
        "variant": "secondary"
      }
    },
    "form-fields": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "email-field",
        "password-field",
        "options-row",
        "signin-btn",
        "google-btn"
      ]
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      }
    },
    "password-field": {
      "type": "Field",
      "props": {
        "label": "Password"
      },
      "children": [
        "password-input"
      ]
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "••••••••",
        "type": "password"
      }
    },
    "options-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 0,
        "align": "center",
        "justify": "between"
      },
      "children": [
        "remember-check",
        "forgot-link"
      ]
    },
    "remember-check": {
      "type": "Checkbox",
      "props": {
        "label": "Remember for 30 days",
        "checked": false
      }
    },
    "forgot-link": {
      "type": "Link",
      "props": {
        "label": "Forgot password?"
      }
    },
    "signin-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "google-btn": {
      "type": "Button",
      "props": {
        "label": "Sign in with Google",
        "variant": "outline",
        "size": "lg",
        "icon": "google",
        "fullWidth": true
      }
    },
    "form-signup": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 1,
        "align": "center"
      },
      "children": [
        "signup-text",
        "signup-link"
      ]
    },
    "signup-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Don't have an account?",
        "variant": "secondary"
      }
    },
    "signup-link": {
      "type": "Link",
      "props": {
        "label": "Sign up"
      }
    },
    "form-footer": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "padding": [
          2,
          4
        ]
      },
      "children": [
        "footer-text"
      ]
    },
    "footer-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "© Daub 2026",
        "variant": "secondary"
      }
    },
    "showcase-panel": {
      "type": "Surface",
      "props": {
        "variant": "sunken",
        "padding": 6
      },
      "children": [
        "showcase-inner"
      ]
    },
    "showcase-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "justify": "center",
        "align": "center"
      },
      "children": [
        "mockup-image",
        "showcase-quote"
      ]
    },
    "mockup-image": {
      "type": "Surface",
      "props": {
        "variant": "card",
        "padding": 5
      },
      "children": ["mi-content"]
    },
    "mi-content": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 5 },
      "children": ["mi-header", "mi-stats"]
    },
    "mi-header": {
      "type": "Text",
      "props": { "tag": "h4", "content": "Dashboard Overview", "weight": "semibold" }
    },
    "mi-stats": {
      "type": "Grid",
      "props": { "columns": 2, "gap": 4 },
      "children": ["mi-s1", "mi-s2", "mi-s3", "mi-s4"]
    },
    "mi-s1": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 1 },
      "children": ["mi-s1-v", "mi-s1-l"]
    },
    "mi-s1-v": { "type": "Text", "props": { "tag": "h3", "content": "2,420" } },
    "mi-s1-l": { "type": "Text", "props": { "tag": "span", "content": "Active users", "variant": "secondary" } },
    "mi-s2": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 1 },
      "children": ["mi-s2-v", "mi-s2-l"]
    },
    "mi-s2-v": { "type": "Text", "props": { "tag": "h3", "content": "$45.2k" } },
    "mi-s2-l": { "type": "Text", "props": { "tag": "span", "content": "Revenue", "variant": "secondary" } },
    "mi-s3": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 1 },
      "children": ["mi-s3-v", "mi-s3-l"]
    },
    "mi-s3-v": { "type": "Text", "props": { "tag": "h3", "content": "+18%" } },
    "mi-s3-l": { "type": "Text", "props": { "tag": "span", "content": "Growth", "variant": "secondary" } },
    "mi-s4": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 1 },
      "children": ["mi-s4-v", "mi-s4-l"]
    },
    "mi-s4-v": { "type": "Text", "props": { "tag": "h3", "content": "99.9%" } },
    "mi-s4-l": { "type": "Text", "props": { "tag": "span", "content": "Uptime", "variant": "secondary" } },
    "showcase-quote": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "align": "center"
      },
      "children": [
        "quote-text",
        "quote-author"
      ]
    },
    "quote-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "\"We've been using Daub to kick start every new project and can't imagine working without it.\"",
        "variant": "secondary",
        "align": "center"
      }
    },
    "quote-author": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3,
        "align": "center"
      },
      "children": [
        "author-avatar",
        "author-info"
      ]
    },
    "author-avatar": {
      "type": "Avatar",
      "props": {
        "initials": "KW",
        "size": "sm"
      }
    },
    "author-info": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "author-name",
        "author-role"
      ]
    },
    "author-name": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Kelly Williams"
      }
    },
    "author-role": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Head of Design, Layers",
        "variant": "secondary"
      }
    }
  }
}
