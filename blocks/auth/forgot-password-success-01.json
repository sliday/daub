{
  "root": "forgot-password-success",
  "elements": {
    "forgot-password-success": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 8,
        "align": "center",
        "justify": "center",
        "container": "narrow"
      },
      "children": [
        "header",
        "content",
        "back-btn"
      ]
    },
    "header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "align": "center"
      },
      "children": [
        "featured-icon",
        "header-text"
      ]
    },
    "featured-icon": {
      "type": "Icon",
      "props": {
        "name": "check-circle",
        "size": "lg",
        "variant": "success"
      }
    },
    "header-text": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3,
        "align": "center"
      },
      "children": [
        "title",
        "subtitle"
      ]
    },
    "title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Password reset",
        "align": "center"
      }
    },
    "subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Your password has been successfully reset.\nClick below to log in magically.",
        "variant": "secondary",
        "align": "center"
      }
    },
    "content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "continue-btn"
      ]
    },
    "continue-btn": {
      "type": "Button",
      "props": {
        "label": "Continue",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "back-btn": {
      "type": "Link",
      "props": {
        "label": "Back to log in"
      }
    }
  }
}
