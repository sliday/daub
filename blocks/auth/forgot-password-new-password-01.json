{
  "root": "forgot-password-new-password",
  "elements": {
    "forgot-password-new-password": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 8,
        "align": "center",
        "justify": "center",
        "container": "narrow"
      },
      "children": [
        "header",
        "content",
        "back-btn"
      ]
    },
    "header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6,
        "align": "center"
      },
      "children": [
        "featured-icon",
        "header-text"
      ]
    },
    "featured-icon": {
      "type": "Icon",
      "props": {
        "name": "key",
        "size": "lg",
        "variant": "branded"
      }
    },
    "header-text": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3,
        "align": "center"
      },
      "children": [
        "title",
        "subtitle"
      ]
    },
    "title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Set new password",
        "align": "center"
      }
    },
    "subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Your new password must be different to previously used passwords.",
        "variant": "secondary",
        "align": "center"
      }
    },
    "content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6
      },
      "children": [
        "form",
        "reset-btn"
      ]
    },
    "form": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 5
      },
      "children": [
        "password-field",
        "confirm-password-field"
      ]
    },
    "password-field": {
      "type": "Field",
      "props": {
        "label": "Password",
        "hint": "Must be at least 8 characters."
      },
      "children": [
        "password-input"
      ]
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "••••••••",
        "type": "password"
      }
    },
    "confirm-password-field": {
      "type": "Field",
      "props": {
        "label": "Confirm password"
      },
      "children": [
        "confirm-password-input"
      ]
    },
    "confirm-password-input": {
      "type": "Input",
      "props": {
        "placeholder": "••••••••",
        "type": "password"
      }
    },
    "reset-btn": {
      "type": "Button",
      "props": {
        "label": "Reset password",
        "variant": "primary",
        "size": "lg",
        "fullWidth": true
      }
    },
    "back-btn": {
      "type": "Link",
      "props": {
        "label": "Back to log in"
      }
    }
  }
}
