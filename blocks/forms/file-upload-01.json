{
  "root": "upload-section",
  "elements": {
    "upload-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "upload-heading",
        "drop-zone",
        "file-list",
        "upload-actions"
      ]
    },
    "upload-heading": {
      "type": "Text",
      "props": {
        "tag": "h3",
        "content": "Upload Files",
        "weight": "semibold"
      }
    },
    "drop-zone": {
      "type": "Surface",
      "props": {
        "variant": "bordered"
      },
      "children": [
        "drop-zone-content"
      ]
    },
    "drop-zone-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "drop-icon-text",
        "drop-hint",
        "btn-browse"
      ]
    },
    "drop-icon-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Drag and drop files here, or click to browse",
        "weight": "medium",
        "align": "center"
      }
    },
    "drop-hint": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Supports PNG, JPG, PDF, and SVG up to 10 MB each",
        "variant": "muted",
        "align": "center"
      }
    },
    "btn-browse": {
      "type": "Button",
      "props": {
        "label": "Browse Files",
        "variant": "outline",
        "icon": "upload"
      }
    },
    "file-list": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "file-item-1",
        "file-item-2",
        "file-item-3"
      ]
    },
    "file-item-1": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3,
        "align": "center",
        "justify": "space-between"
      },
      "children": [
        "file-1-info",
        "file-1-progress",
        "file-1-actions"
      ]
    },
    "file-1-info": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "file-1-name",
        "file-1-size"
      ]
    },
    "file-1-name": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "brand-guidelines-v2.pdf",
        "weight": "medium"
      }
    },
    "file-1-size": {
      "type": "Badge",
      "props": {
        "text": "2.4 MB",
        "variant": "secondary"
      }
    },
    "file-1-progress": {
      "type": "Progress",
      "props": {
        "value": 100,
        "max": 100
      }
    },
    "file-1-actions": {
      "type": "Button",
      "props": {
        "label": "Remove",
        "variant": "ghost",
        "size": "sm",
        "icon": "x"
      }
    },
    "file-item-2": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3,
        "align": "center",
        "justify": "space-between"
      },
      "children": [
        "file-2-info",
        "file-2-progress",
        "file-2-actions"
      ]
    },
    "file-2-info": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "file-2-name",
        "file-2-size"
      ]
    },
    "file-2-name": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "homepage-mockup.png",
        "weight": "medium"
      }
    },
    "file-2-size": {
      "type": "Badge",
      "props": {
        "text": "1.8 MB",
        "variant": "secondary"
      }
    },
    "file-2-progress": {
      "type": "Progress",
      "props": {
        "value": 67,
        "max": 100,
        "label": "67%"
      }
    },
    "file-2-actions": {
      "type": "Button",
      "props": {
        "label": "Cancel",
        "variant": "ghost",
        "size": "sm",
        "icon": "x"
      }
    },
    "file-item-3": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3,
        "align": "center",
        "justify": "space-between"
      },
      "children": [
        "file-3-info",
        "file-3-progress",
        "file-3-actions"
      ]
    },
    "file-3-info": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "file-3-name",
        "file-3-size"
      ]
    },
    "file-3-name": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "logo-dark.svg",
        "weight": "medium"
      }
    },
    "file-3-size": {
      "type": "Badge",
      "props": {
        "text": "24 KB",
        "variant": "secondary"
      }
    },
    "file-3-progress": {
      "type": "Progress",
      "props": {
        "value": 100,
        "max": 100
      }
    },
    "file-3-actions": {
      "type": "Button",
      "props": {
        "label": "Remove",
        "variant": "ghost",
        "size": "sm",
        "icon": "x"
      }
    },
    "upload-actions": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "justify": "flex-end"
      },
      "children": [
        "btn-clear-all",
        "btn-upload-all"
      ]
    },
    "btn-clear-all": {
      "type": "Button",
      "props": {
        "label": "Clear All",
        "variant": "outline"
      }
    },
    "btn-upload-all": {
      "type": "Button",
      "props": {
        "label": "Upload All",
        "variant": "default",
        "icon": "upload-cloud"
      }
    }
  }
}
