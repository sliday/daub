{
  "root": "schedule-tabs",
  "elements": {
    "schedule-tabs": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "container": true
      },
      "children": [
        "schedule-header",
        "schedule-tabs-nav"
      ]
    },
    "schedule-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1,
        "align": "center"
      },
      "children": [
        "schedule-title",
        "schedule-subtitle"
      ]
    },
    "schedule-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Conference Schedule",
        "weight": "bold",
        "align": "center"
      }
    },
    "schedule-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Two days of talks, workshops, and networking. All times in Pacific Time.",
        "variant": "muted",
        "align": "center"
      }
    },
    "schedule-tabs-nav": {
      "type": "Tabs",
      "props": {
        "items": [
          {
            "label": "Day 1 — June 14",
