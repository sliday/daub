{
  "root": "cta-split-image",
  "elements": {
    "cta-split-image": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": -6
      },
      "children": [
        "background-image",
        "overlap-container"
      ]
    },
    "background-image": {
      "type": "Image",
      "props": {
        "src": "data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%221440%22%20height%3D%22400%22%3E%3Cdefs%3E%3ClinearGradient%20id%3D%22g1%22%20x1%3D%220%25%22%20y1%3D%220%25%22%20x2%3D%22100%25%22%20y2%3D%220%25%22%3E%3Cstop%20offset%3D%220%25%22%20stop-color%3D%22%237F56D9%22%2F%3E%3Cstop%20offset%3D%2250%25%22%20stop-color%3D%22%236941C6%22%2F%3E%3Cstop%20offset%3D%22100%25%22%20stop-color%3D%22%237F56D9%22%2F%3E%3C%2FlinearGradient%3E%3C%2Fdefs%3E%3Crect%20width%3D%221440%22%20height%3D%22400%22%20fill%3D%22url(%23g1)%22%2F%3E%3Ccircle%20cx%3D%22200%22%20cy%3D%2280%22%20r%3D%22160%22%20fill%3D%22%23E4E7EC%22%20opacity%3D%220.08%22%2F%3E%3Ccircle%20cx%3D%221200%22%20cy%3D%22320%22%20r%3D%22200%22%20fill%3D%22%23E4E7EC%22%20opacity%3D%220.06%22%2F%3E%3Cpath%20d%3D%22M0%20300Q360%20200%20720%20280T1440%20200V400H0Z%22%20fill%3D%22%236941C6%22%20opacity%3D%220.4%22%2F%3E%3Crect%20x%3D%22600%22%20y%3D%2260%22%20width%3D%22240%22%20height%3D%22240%22%20rx%3D%2230%22%20fill%3D%22%23fff%22%20opacity%3D%220.05%22%20transform%3D%22rotate(15%20720%20180)%22%2F%3E%3C%2Fsvg%3E",
        "alt": "CTA background",
        "objectFit": "cover"
      }
    },
    "overlap-container": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "container": "wide",
        "padding": [0, 8]
      },
      "children": [
        "overlap-card"
      ]
    },
    "overlap-card": {
      "type": "Card",
      "props": {
        "padding": 12,
        "elevated": true
      },
      "children": [
        "card-inner"
      ]
    },
    "card-inner": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "align": "center",
        "justify": "between",
        "gap": 8
      },
      "children": [
        "card-text",
        "card-buttons"
      ]
    },
    "card-text": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "heading",
        "description"
      ]
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Start your free trial"
      }
    },
    "description": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Join over 4,000+ startups already growing with Daub.",
        "variant": "secondary"
      }
    },
    "card-buttons": {
      "type": "ButtonGroup",
      "children": [
        "btn-learn",
        "btn-start"
      ]
    },
    "btn-learn": {
      "type": "Button",
      "props": {
        "label": "Learn more",
        "variant": "outline",
        "size": "lg"
      }
    },
    "btn-start": {
      "type": "Button",
      "props": {
        "label": "Get started",
        "variant": "primary",
        "size": "lg"
      }
    }
  }
}
