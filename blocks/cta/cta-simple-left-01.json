{
  "root": "cta-simple-left",
  "elements": {
    "cta-simple-left": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 10,
        "padding": [24, 0]
      },
      "children": [
        "container"
      ]
    },
    "container": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 8,
        "align": "center",
        "justify": "between",
        "container": "wide"
      },
      "children": [
        "content",
        "actions"
      ]
    },
    "content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 5
      },
      "children": [
        "heading",
        "subheading"
      ]
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Start your free trial"
      }
    },
    "subheading": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Join over 4,000+ startups already growing with Daub.",
        "variant": "secondary"
      }
    },
    "actions": {
      "type": "ButtonGroup",
      "children": [
        "btn-secondary",
        "btn-primary"
      ]
    },
    "btn-secondary": {
      "type": "Button",
      "props": {
        "label": "Learn more",
        "variant": "outline",
        "size": "lg"
      }
    },
    "btn-primary": {
      "type": "Button",
      "props": {
        "label": "Get started",
        "variant": "primary",
        "size": "lg"
      }
    }
  }
}
