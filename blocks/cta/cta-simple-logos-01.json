{
  "root": "cta-simple-logos-01",
  "elements": {
    "cta-simple-logos-01": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 10,
        "padding": [24, 0]
      },
      "children": [
        "container"
      ]
    },
    "container": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 8,
        "container": "wide"
      },
      "children": [
        "top-row",
        "divider",
        "logos-row"
      ]
    },
    "top-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 8,
        "align": "center",
        "justify": "between"
      },
      "children": [
        "content",
        "actions"
      ]
    },
    "content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 5
      },
      "children": [
        "heading",
        "subheading"
      ]
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Start your free trial"
      }
    },
    "subheading": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Join over 4,000+ startups already growing with Daub.",
        "variant": "secondary"
      }
    },
    "actions": {
      "type": "ButtonGroup",
      "children": [
        "btn-secondary",
        "btn-primary"
      ]
    },
    "btn-secondary": {
      "type": "Button",
      "props": {
        "label": "Learn more",
        "variant": "outline",
        "size": "lg"
      }
    },
    "btn-primary": {
      "type": "Button",
      "props": {
        "label": "Get started",
        "variant": "primary",
        "size": "lg"
      }
    },
    "divider": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "logos-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 8,
        "justify": "center",
        "align": "center"
      },
      "children": [
        "logo-1",
        "logo-2",
        "logo-3",
        "logo-4",
        "logo-5",
        "logo-6"
      ]
    },
    "logo-1": {
      "type": "Icon",
      "props": { "name": "building-2", "size": "lg", "variant": "muted" }
    },
    "logo-2": {
      "type": "Icon",
      "props": { "name": "hexagon", "size": "lg", "variant": "muted" }
    },
    "logo-3": {
      "type": "Icon",
      "props": { "name": "triangle", "size": "lg", "variant": "muted" }
    },
    "logo-4": {
      "type": "Icon",
      "props": { "name": "diamond", "size": "lg", "variant": "muted" }
    },
    "logo-5": {
      "type": "Icon",
      "props": { "name": "pentagon", "size": "lg", "variant": "muted" }
    },
    "logo-6": {
      "type": "Icon",
      "props": { "name": "circle", "size": "lg", "variant": "muted" }
    }
  }
}
