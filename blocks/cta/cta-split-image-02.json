{
  "root": "cta-split-image",
  "elements": {
    "cta-split-image": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 0
      },
      "children": [
        "left-image",
        "right-content"
      ]
    },
    "left-image": {
      "type": "Image",
      "props": {
        "src": "data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22720%22%20height%3D%22720%22%3E%3Cdefs%3E%3CradialGradient%20id%3D%22g1%22%20cx%3D%2230%25%22%20cy%3D%2270%25%22%20r%3D%2280%25%22%3E%3Cstop%20offset%3D%220%25%22%20stop-color%3D%22%239B7FE6%22%2F%3E%3Cstop%20offset%3D%22100%25%22%20stop-color%3D%22%237F56D9%22%2F%3E%3C%2FradialGradient%3E%3C%2Fdefs%3E%3Crect%20width%3D%22720%22%20height%3D%22720%22%20fill%3D%22url(%23g1)%22%2F%3E%3Cellipse%20cx%3D%22360%22%20cy%3D%22360%22%20rx%3D%22280%22%20ry%3D%22200%22%20fill%3D%22%23E4E7EC%22%20opacity%3D%220.12%22%2F%3E%3Cpath%20d%3D%22M0%20500Q180%20350%20360%20500T720%20500V720H0Z%22%20fill%3D%22%236941C6%22%20opacity%3D%220.3%22%2F%3E%3Ccircle%20cx%3D%22580%22%20cy%3D%22140%22%20r%3D%2290%22%20fill%3D%22%23fff%22%20opacity%3D%220.1%22%2F%3E%3Ccircle%20cx%3D%22140%22%20cy%3D%22180%22%20r%3D%2260%22%20fill%3D%22%23E4E7EC%22%20opacity%3D%220.15%22%2F%3E%3C%2Fsvg%3E",
        "alt": "CTA hero",
        "objectFit": "cover",
        "fullHeight": true
      }
    },
    "right-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 8,
        "padding": [24, 8],
        "justify": "center",
        "align": "center"
      },
      "children": [
        "text-group",
        "cta-buttons"
      ]
    },
    "text-group": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "align": "center"
      },
      "children": [
        "heading",
        "description"
      ]
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Start your free trial",
        "align": "center"
      }
    },
    "description": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Join over 4,000+ startups already growing with Daub.",
        "variant": "secondary",
        "align": "center"
      }
    },
    "cta-buttons": {
      "type": "ButtonGroup",
      "children": [
        "btn-learn",
        "btn-start"
      ]
    },
    "btn-learn": {
      "type": "Button",
      "props": {
        "label": "Learn more",
        "variant": "outline",
        "size": "lg"
      }
    },
    "btn-start": {
      "type": "Button",
      "props": {
        "label": "Get started",
        "variant": "primary",
        "size": "lg"
      }
    }
  }
}
