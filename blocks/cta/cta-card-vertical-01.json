{
  "root": "cta-card-v",
  "elements": {
    "cta-card-v": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "align": "center",
        "padding": [24, 0]
      },
      "children": [
        "card-container"
      ]
    },
    "card-container": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "container": "wide",
        "padding": [0, 8]
      },
      "children": [
        "card"
      ]
    },
    "card": {
      "type": "Card",
      "props": {
        "variant": "muted",
        "padding": 16
      },
      "children": [
        "card-content"
      ]
    },
    "card-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 8,
        "align": "center"
      },
      "children": [
        "text-content",
        "actions"
      ]
    },
    "text-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 5,
        "align": "center"
      },
      "children": [
        "heading",
        "subheading"
      ]
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Start your free trial",
        "align": "center"
      }
    },
    "subheading": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Join over 4,000+ startups already growing with Daub.",
        "variant": "secondary",
        "align": "center"
      }
    },
    "actions": {
      "type": "ButtonGroup",
      "children": [
        "btn-secondary",
        "btn-primary"
      ]
    },
    "btn-secondary": {
      "type": "Button",
      "props": {
        "label": "Learn more",
        "variant": "outline",
        "size": "lg"
      }
    },
    "btn-primary": {
      "type": "Button",
      "props": {
        "label": "Get started",
        "variant": "primary",
        "size": "lg"
      }
    }
  }
}
