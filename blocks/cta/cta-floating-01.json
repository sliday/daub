{
  "root": "cta-floating",
  "elements": {
    "cta-floating": {
      "type": "Surface",
      "props": {
        "variant": "raised"
      },
      "children": [
        "floating-inner"
      ]
    },
    "floating-inner": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 4,
        "align": "center",
        "justify": "between",
        "container": "wide"
      },
      "children": [
        "floating-left",
        "floating-right"
      ]
    },
    "floating-left": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3,
        "align": "center"
      },
      "children": [
        "floating-icon",
        "floating-text"
      ]
    },
    "floating-icon": {
      "type": "Badge",
      "props": {
        "text": "NEW",
        "variant": "new"
      }
    },
    "floating-text": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "floating-title",
        "floating-desc"
      ]
    },
    "floating-title": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Announcing Relay 2.0 — real-time collaboration for every team",
        "weight": "semibold"
      }
    },
    "floating-desc": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Multiplayer editing, live cursors, and instant sync across all devices.",
        "variant": "muted"
      }
    },
    "floating-right": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "floating-btn",
        "floating-dismiss"
      ]
    },
    "floating-btn": {
      "type": "Button",
      "props": {
        "label": "Try it free",
        "variant": "primary"
      }
    },
    "floating-dismiss": {
      "type": "Button",
      "props": {
        "label": "Dismiss",
        "variant": "ghost",
        "icon": "x"
      }
    }
  }
}
