{
  "root": "cta-split-image",
  "elements": {
    "cta-split-image": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 0
      },
      "children": [
        "left-content",
        "right-image"
      ]
    },
    "left-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 8,
        "padding": [24, 8],
        "justify": "end"
      },
      "children": [
        "content-group",
        "cta-buttons"
      ]
    },
    "content-group": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 8
      },
      "children": [
        "heading",
        "check-list"
      ]
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Join 4,000+ startups growing with Daub"
      }
    },
    "check-list": {
      "type": "List",
      "props": {
        "variant": "check",
        "gap": 5,
        "items": [
          "30-day free trial",
          "Pesonalized onboarding",
          "Access to all features"
        ]
      }
    },
    "cta-buttons": {
      "type": "ButtonGroup",
      "children": [
        "btn-learn",
        "btn-start"
      ]
    },
    "btn-learn": {
      "type": "Button",
      "props": {
        "label": "Learn more",
        "variant": "outline",
        "size": "lg"
      }
    },
    "btn-start": {
      "type": "Button",
      "props": {
        "label": "Get started",
        "variant": "primary",
        "size": "lg"
      }
    },
    "right-image": {
      "type": "Image",
      "props": {
        "src": "data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22720%22%20height%3D%22720%22%3E%3Cdefs%3E%3ClinearGradient%20id%3D%22g1%22%20x1%3D%220%25%22%20y1%3D%220%25%22%20x2%3D%22100%25%22%20y2%3D%22100%25%22%3E%3Cstop%20offset%3D%220%25%22%20stop-color%3D%22%237F56D9%22%2F%3E%3Cstop%20offset%3D%22100%25%22%20stop-color%3D%22%23E4E7EC%22%2F%3E%3C%2FlinearGradient%3E%3C%2Fdefs%3E%3Crect%20width%3D%22720%22%20height%3D%22720%22%20fill%3D%22url(%23g1)%22%2F%3E%3Ccircle%20cx%3D%22520%22%20cy%3D%22200%22%20r%3D%22180%22%20fill%3D%22%237F56D9%22%20opacity%3D%220.3%22%2F%3E%3Ccircle%20cx%3D%22200%22%20cy%3D%22520%22%20r%3D%22220%22%20fill%3D%22%23E4E7EC%22%20opacity%3D%220.25%22%2F%3E%3Crect%20x%3D%22300%22%20y%3D%22300%22%20width%3D%22200%22%20height%3D%22200%22%20rx%3D%2220%22%20fill%3D%22%23fff%22%20opacity%3D%220.15%22%20transform%3D%22rotate(25%20400%20400)%22%2F%3E%3C%2Fsvg%3E",
        "alt": "CTA hero image",
        "objectFit": "cover",
        "fullHeight": true
      }
    }
  }
}
