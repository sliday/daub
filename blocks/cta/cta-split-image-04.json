{
  "root": "cta-split-image",
  "elements": {
    "cta-split-image": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 0
      },
      "children": [
        "left-image",
        "right-content"
      ]
    },
    "left-image": {
      "type": "Image",
      "props": {
        "src": "data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22720%22%20height%3D%22720%22%3E%3Cdefs%3E%3ClinearGradient%20id%3D%22g1%22%20x1%3D%220%25%22%20y1%3D%22100%25%22%20x2%3D%22100%25%22%20y2%3D%220%25%22%3E%3Cstop%20offset%3D%220%25%22%20stop-color%3D%22%237F56D9%22%2F%3E%3Cstop%20offset%3D%22100%25%22%20stop-color%3D%22%23E4E7EC%22%2F%3E%3C%2FlinearGradient%3E%3CradialGradient%20id%3D%22g2%22%20cx%3D%2270%25%22%20cy%3D%2230%25%22%20r%3D%2250%25%22%3E%3Cstop%20offset%3D%220%25%22%20stop-color%3D%22%23fff%22%20stop-opacity%3D%220.2%22%2F%3E%3Cstop%20offset%3D%22100%25%22%20stop-color%3D%22%23fff%22%20stop-opacity%3D%220%22%2F%3E%3C%2FradialGradient%3E%3C%2Fdefs%3E%3Crect%20width%3D%22720%22%20height%3D%22720%22%20fill%3D%22url(%23g1)%22%2F%3E%3Crect%20width%3D%22720%22%20height%3D%22720%22%20fill%3D%22url(%23g2)%22%2F%3E%3Cpolygon%20points%3D%220%2C720%20360%2C400%20720%2C720%22%20fill%3D%22%236941C6%22%20opacity%3D%220.2%22%2F%3E%3Cpolygon%20points%3D%22100%2C0%20450%2C300%200%2C350%22%20fill%3D%22%23E4E7EC%22%20opacity%3D%220.1%22%2F%3E%3Ccircle%20cx%3D%22560%22%20cy%3D%22160%22%20r%3D%22100%22%20fill%3D%22%237F56D9%22%20opacity%3D%220.25%22%2F%3E%3Ccircle%20cx%3D%22360%22%20cy%3D%22500%22%20r%3D%2270%22%20fill%3D%22%23fff%22%20opacity%3D%220.1%22%2F%3E%3C%2Fsvg%3E",
        "alt": "CTA hero",
        "objectFit": "cover",
        "fullHeight": true
      }
    },
    "right-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 8,
        "padding": [24, 8],
        "justify": "center"
      },
      "children": [
        "content-group",
        "cta-buttons"
      ]
    },
    "content-group": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 6
      },
      "children": [
        "heading",
        "description",
        "check-list"
      ]
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Start your free trial today"
      }
    },
    "description": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Join over 4,000+ startups already growing with Daub.",
        "variant": "secondary"
      }
    },
    "check-list": {
      "type": "List",
      "props": {
        "variant": "check",
        "gap": 4,
        "items": [
          "30-day free trial",
          "Pesonalized onboarding",
          "Access to all features"
        ]
      }
    },
    "cta-buttons": {
      "type": "ButtonGroup",
      "children": [
        "btn-learn",
        "btn-start"
      ]
    },
    "btn-learn": {
      "type": "Button",
      "props": {
        "label": "Learn more",
        "variant": "outline",
        "size": "lg"
      }
    },
    "btn-start": {
      "type": "Button",
      "props": {
        "label": "Get started",
        "variant": "primary",
        "size": "lg"
      }
    }
  }
}
