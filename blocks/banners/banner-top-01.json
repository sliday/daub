{
  "root": "banner-top",
  "elements": {
    "banner-top": {
      "type": "Surface",
      "props": {
        "variant": "flat"
      },
      "children": [
        "banner-top-inner"
      ]
    },
    "banner-top-inner": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3,
        "align": "center",
        "justify": "center",
        "container": true
      },
      "children": [
        "banner-top-badge",
        "banner-top-text",
        "banner-top-cta",
        "banner-top-dismiss"
      ]
    },
    "banner-top-badge": {
      "type": "Badge",
      "props": {
        "text": "New",
        "variant": "default"
      }
    },
    "banner-top-text": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "We just launched AI-powered analytics. Understand your data 10x faster with natural language queries."
      }
    },
    "banner-top-cta": {
      "type": "Button",
      "props": {
        "label": "Learn More",
        "variant": "outline",
        "size": "sm",
        "icon": "arrow-right"
      }
    },
    "banner-top-dismiss": {
      "type": "Button",
      "props": {
        "label": "",
        "variant": "ghost",
        "size": "sm",
        "icon": "x"
      }
    }
  }
}
