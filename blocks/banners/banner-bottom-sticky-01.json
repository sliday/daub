{
  "root": "banner-bottom-sticky",
  "elements": {
    "banner-bottom-sticky": {
      "type": "Surface",
      "props": {
        "variant": "raised"
      },
      "children": [
        "banner-bottom-inner"
      ]
    },
    "banner-bottom-inner": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3,
        "align": "center",
        "justify": "space-between",
        "container": true
      },
      "children": [
        "banner-bottom-text-block",
        "banner-bottom-actions"
      ]
    },
    "banner-bottom-text-block": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0
      },
      "children": [
        "banner-bottom-title",
        "banner-bottom-desc"
      ]
    },
    "banner-bottom-title": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "We value your privacy",
        "weight": "bold"
      }
    },
    "banner-bottom-desc": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "We use cookies to improve your experience, analyze traffic, and personalize content. You can manage your preferences at any time.",
        "variant": "muted"
      }
    },
    "banner-bottom-actions": {
      "type": "ButtonGroup",
      "children": [
        "banner-bottom-accept",
        "banner-bottom-settings",
        "banner-bottom-reject"
      ]
    },
    "banner-bottom-accept": {
      "type": "Button",
      "props": {
        "label": "Accept All",
        "variant": "default",
        "size": "sm"
      }
    },
    "banner-bottom-settings": {
      "type": "Button",
      "props": {
        "label": "Manage Preferences",
        "variant": "outline",
        "size": "sm"
      }
    },
    "banner-bottom-reject": {
      "type": "Button",
      "props": {
        "label": "Reject Non-Essential",
        "variant": "ghost",
        "size": "sm"
      }
    }
  }
}
