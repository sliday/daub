{
  "root": "pricing-calculator",
  "elements": {
    "pricing-calculator": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 5,
        "align": "center",
        "container": "narrow"
      },
      "children": [
        "calc-header",
        "calc-card"
      ]
    },
    "calc-header": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1,
        "align": "center"
      },
      "children": [
        "calc-title",
        "calc-subtitle"
      ]
    },
    "calc-title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Estimate your cost",
        "align": "center"
      }
    },
    "calc-subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Pay only for what you use. No minimums, no commitments.",
        "variant": "muted",
        "align": "center"
      }
    },
    "calc-card": {
      "type": "Surface",
      "props": {
        "variant": "bordered"
      },
      "children": [
        "calc-inner"
      ]
    },
    "calc-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 5
      },
      "children": [
        "slider-requests",
        "slider-storage",
        "slider-bandwidth",
        "calc-sep",
        "calc-total-row",
        "calc-breakdown",
        "calc-cta"
      ]
    },
    "slider-requests": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "requests-label-row",
        "requests-slider"
      ]
    },
    "requests-label-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "justify": "between"
      },
      "children": [
        "requests-label",
        "requests-value"
      ]
    },
    "requests-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "API Requests / month",
        "weight": "semibold"
      }
    },
    "requests-value": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "5 million"
      }
    },
    "requests-slider": {
      "type": "Slider",
      "props": {
        "min": 0,
        "max": 100,
        "step": 1,
        "defaultValue": 50
      }
    },
    "slider-storage": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "storage-label-row",
        "storage-slider"
      ]
    },
    "storage-label-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "justify": "between"
      },
      "children": [
        "storage-label",
        "storage-value"
      ]
    },
    "storage-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Data Storage",
        "weight": "semibold"
      }
    },
    "storage-value": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "250 GB"
      }
    },
    "storage-slider": {
      "type": "Slider",
      "props": {
        "min": 0,
        "max": 100,
        "step": 1,
        "defaultValue": 25
      }
    },
    "slider-bandwidth": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "bandwidth-label-row",
        "bandwidth-slider"
      ]
    },
    "bandwidth-label-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "justify": "between"
      },
      "children": [
        "bandwidth-label",
        "bandwidth-value"
      ]
    },
    "bandwidth-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Bandwidth",
        "weight": "semibold"
      }
    },
    "bandwidth-value": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "500 GB"
      }
    },
    "bandwidth-slider": {
      "type": "Slider",
      "props": {
        "min": 0,
        "max": 100,
        "step": 1,
        "defaultValue": 50
      }
    },
    "calc-sep": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "calc-total-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "justify": "between",
        "align": "center"
      },
      "children": [
        "total-label",
        "total-price"
      ]
    },
    "total-label": {
      "type": "Text",
      "props": {
        "tag": "h4",
        "content": "Estimated monthly cost"
      }
    },
    "total-price": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "$347"
      }
    },
    "calc-breakdown": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "breakdown-requests",
        "breakdown-storage",
        "breakdown-bandwidth"
      ]
    },
    "breakdown-requests": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "justify": "between"
      },
      "children": [
        "breakdown-requests-label",
        "breakdown-requests-price"
      ]
    },
    "breakdown-requests-label": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "5M API requests",
        "variant": "muted"
      }
    },
    "breakdown-requests-price": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "$175",
        "variant": "muted"
      }
    },
    "breakdown-storage": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "justify": "between"
      },
      "children": [
        "breakdown-storage-label",
        "breakdown-storage-price"
      ]
    },
    "breakdown-storage-label": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "250 GB storage",
        "variant": "muted"
      }
    },
    "breakdown-storage-price": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "$62",
        "variant": "muted"
      }
    },
    "breakdown-bandwidth": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "justify": "between"
      },
      "children": [
        "breakdown-bandwidth-label",
        "breakdown-bandwidth-price"
      ]
    },
    "breakdown-bandwidth-label": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "500 GB bandwidth",
        "variant": "muted"
      }
    },
    "breakdown-bandwidth-price": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "$110",
        "variant": "muted"
      }
    },
    "calc-cta": {
      "type": "Button",
      "props": {
        "label": "Start building for free",
        "variant": "primary",
        "size": "lg"
      }
    }
  }
}
