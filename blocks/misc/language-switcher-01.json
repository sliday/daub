{
  "root": "language-switcher-root",
  "elements": {
    "language-switcher-root": {
      "type": "Stack",
      "direction": "horizontal",
      "gap": 2,
      "align": "center",
      "children": ["language-icon-text", "language-select"]
    },
    "language-icon-text": {
      "type": "Text",
      "tag": "span",
      "content": "Language",
      "variant": "muted"
    },
    "language-select": {
      "type": "Select",
      "label": "Language",
      "options": [
        { "label": "English", "value": "en" },
        { "label": "Espanol", "value": "es" },
        { "label": "Francais", "value": "fr" },
        { "label": "Deutsch", "value": "de" },
        { "label": "Japanese", "value": "ja" }
      ]
    }
  }
}
