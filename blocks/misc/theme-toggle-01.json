{
  "root": "theme-toggle-root",
  "elements": {
    "theme-toggle-root": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "theme-sun-label",
        "theme-toggle-switch",
        "theme-moon-label"
      ]
    },
    "theme-sun-label": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Light"
      }
    },
    "theme-toggle-switch": {
      "type": "Toggle",
      "props": {
        "label": "Toggle dark mode",
        "pressed": false
      }
    },
    "theme-moon-label": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Dark",
        "variant": "muted"
      }
    }
  }
}
