{
  "root": "command-palette-section",
  "elements": {
    "command-palette-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 0,
        "align": "center",
        "container": "narrow"
      },
      "children": ["palette-card"]
    },
    "palette-card": {
      "type": "Card",
      "children": ["palette-inner"]
    },
    "palette-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3
      },
      "children": ["palette-search", "palette-divider", "palette-results"]
    },
    "palette-search": {
      "type": "Input",
      "props": {
        "placeholder": "Type a command or search...",
        "type": "search"
      }
    },
    "palette-divider": {
      "type": "Separator",
      "props": { "orientation": "horizontal" }
    },
    "palette-results": {
      "type": "List",
      "props": {
        "items": [
          { "primary": "New Project", "icon": "plus", "meta": "Ctrl+N" },
          { "primary": "Open File", "icon": "file", "meta": "Ctrl+O" },
          { "primary": "Search Documentation", "icon": "search", "meta": "Ctrl+K" },
          { "primary": "Toggle Dark Mode", "icon": "moon", "meta": "Ctrl+Shift+D" },
          { "primary": "Invite Team Member", "icon": "user-plus", "meta": "Ctrl+I" },
          { "primary": "Go to Dashboard", "icon": "layout-dashboard", "meta": "G D" },
          { "primary": "Go to Settings", "icon": "settings", "meta": "G S" },
          { "primary": "Go to Projects", "icon": "folder", "meta": "G P" },
          { "primary": "Export Data", "icon": "download", "meta": "Ctrl+E" },
          { "primary": "View Notifications", "icon": "bell", "meta": "Ctrl+Shift+N" },
          { "primary": "Open Terminal", "icon": "terminal", "meta": "Ctrl+`" },
          { "primary": "Sign Out", "icon": "log-out" }
        ]
      }
    }
  }
}
