{
  "root": "team-carousel",
  "elements": {
    "team-carousel": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "container": true
      },
      "children": [
        "tc-header",
        "tc-sub",
        "tc-slider",
        "tc-nav"
      ]
    },
    "tc-header": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "The People Behind the Product",
        "weight": "bold",
        "align": "center"
      }
    },
    "tc-sub": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "A world-class team passionate about building tools developers love.",
        "variant": "muted",
        "align": "center"
      }
    },
    "tc-slider": {
      "type": "Carousel",
      "children": [
        "tc-slide-1",
        "tc-slide-2",
        "tc-slide-3",
        "tc-slide-4",
        "tc-slide-5"
      ]
    },
    "tc-slide-1": {
      "type": "Card",
      "children": [
        "tc-s1-inner"
      ]
    },
    "tc-s1-inner": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "tc-s1-img",
        "tc-s1-name",
        "tc-s1-role",
        "tc-s1-bio"
      ]
    },
    "tc-s1-img": {
      "type": "Avatar",
      "props": {
        "src": "https://picsum.photos/seed/mia-torres/200/200",
        "initials": "MT",
        "size": "xl"
      }
    },
    "tc-s1-name": {
      "type": "Text",
      "props": {
        "tag": "h3",
        "content": "Mia Torres",
        "weight": "bold"
      }
    },
    "tc-s1-role": {
      "type": "Chip",
      "props": {
        "label": "Frontend Lead",
        "variant": "secondary"
      }
    },
    "tc-s1-bio": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "React and TypeScript specialist. Built design systems used by Fortune 500 companies.",
        "variant": "muted",
        "align": "center"
      }
