      "children": ["tl-name-4", "tl-role-4", "tl-bio-4"]
    },
    "tl-name-4": {
      "type": "Text",
      "tag": "h4",
      "content": "Omar Hassan",
      "weight": "bold"
    },
    "tl-role-4": {
      "type": "Badge",
      "text": "VP of Engineering",
      "variant": "secondary"
    },
    "tl-bio-4": {
      "type": "Text",
      "tag": "p",
      "content": "Former tech lead at Google Cloud. Omar manages our 28-person engineering org across frontend, backend, and infrastructure teams shipping on a 2-week cadence.",
      "variant": "muted"
    }
  }
}
