      "type": "Text",
      "tag": "h4",
      "content": "Lisa Park",
      "weight": "bold"
    },
    "tl-role-3": {
      "type": "Badge",
      "text": "VP of Product",
      "variant": "secondary"
    },
    "tl-bio-3": {
      "type": "Text",
      "tag": "p",
      "content": "10 years in product at Figma and Notion. Lisa drives our product roadmap, user research program, and design system that powers 500+ component variants.",
      "variant": "muted"
    },
    "tl-sep-3": {
      "type": "Separator",
      "orientation": "horizontal"
    },
    "tl-person-4": {
      "type": "Stack",
      "direction": "horizontal",
      "gap": 3,
      "align": "center",
