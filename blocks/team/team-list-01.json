    "tl-av-3": {
      "type": "Avatar",
      "src": "https://picsum.photos/seed/lisa-park/120/120",
      "initials": "LP",
      "size": "xl"
    },
    "tl-info-3": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 1,
      "children": ["tl-name-3", "tl-role-3", "tl-bio-3"]
    },
