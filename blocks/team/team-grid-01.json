      "props": {
        "tag": "p",
        "content": "The people behind the product. We're a distributed team across 4 time zones, united by a passion for building great software.",
        "variant": "muted",
        "align": "center"
      }
    },
    "team-grid-cards": {
      "type": "Grid",
      "props": {
        "columns": 3,
        "gap": 3
      },
      "children": [
        "team-member-1",
        "team-member-2",
        "team-member-3",
        "team-member-4",
        "team-member-5",
        "team-member-6"
      ]
    },
