    "team-grid": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "container": true
      },
      "children": [
        "team-grid-header",
        "team-grid-sub",
        "team-grid-cards"
      ]
    },
    "team-grid-header": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Meet Our Team",
        "weight": "bold",
        "align": "center"
      }
    },
    "team-grid-sub": {
