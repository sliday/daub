{
  "root": "hero-split",
  "elements": {
    "hero-split": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 6
      },
      "children": [
        "hero-split-content",
        "hero-split-image"
      ]
    },
    "hero-split-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4,
        "justify": "center"
      },
      "children": [
        "hero-split-chip",
        "hero-split-heading",
        "hero-split-text",
        "hero-split-features",
        "hero-split-actions"
      ]
    },
    "hero-split-chip": {
      "type": "Chip",
      "props": {
        "label": "Design Tool",
        "variant": "outline"
      }
    },
    "hero-split-heading": {
      "type": "Text",
      "props": {
        "tag": "h1",
        "content": "Design interfaces 10x faster with AI-powered components",
        "weight": "bold"
      }
    },
    "hero-split-text": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Figma and Sketch are yesterday's tools. Quill generates production-ready designs from natural language, with pixel-perfect responsive layouts out of the box.",
        "variant": "muted"
      }
    },
    "hero-split-features": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2
      },
      "children": [
        "hero-split-feat-1",
        "hero-split-feat-2",
        "hero-split-feat-3"
      ]
    },
    "hero-split-feat-1": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "hero-feat-check-1",
        "hero-feat-text-1"
      ]
    },
    "hero-feat-check-1": {
      "type": "Badge",
      "props": {
        "text": "check",
        "variant": "success"
      }
    },
    "hero-feat-text-1": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Export to React, Vue, or Svelte"
      }
    },
    "hero-split-feat-2": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "hero-feat-check-2",
        "hero-feat-text-2"
      ]
    },
    "hero-feat-check-2": {
      "type": "Badge",
      "props": {
        "text": "check",
        "variant": "success"
      }
    },
    "hero-feat-text-2": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Built-in design system tokens"
      }
    },
    "hero-split-feat-3": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "hero-feat-check-3",
        "hero-feat-text-3"
      ]
    },
    "hero-feat-check-3": {
      "type": "Badge",
      "props": {
        "text": "check",
        "variant": "success"
      }
    },
    "hero-feat-text-3": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Real-time collaboration for teams"
      }
    },
    "hero-split-actions": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 3
      },
      "children": [
        "hero-split-cta",
        "hero-split-demo"
      ]
    },
    "hero-split-cta": {
      "type": "Button",
      "props": {
        "label": "Try Quill Free",
        "variant": "primary",
        "size": "lg"
      }
    },
    "hero-split-demo": {
      "type": "Button",
      "props": {
        "label": "Watch Demo",
        "variant": "ghost",
        "size": "lg",
        "icon": "play"
      }
    },
    "hero-split-image": {
      "type": "Surface",
      "props": {
        "variant": "bordered"
      },
      "children": [
        "hero-split-screenshot"
      ]
    },
    "hero-split-screenshot": {
      "type": "Image",
      "props": {
        "src": "/images/hero-app-screenshot.webp",
        "alt": "Quill design editor showing AI component generation in action"
      }
    }
  }
}
