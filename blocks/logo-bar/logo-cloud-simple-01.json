{
  "root": "logo-grid-section",
  "elements": {
    "logo-grid-section": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 5,
      "align": "center",
      "children": ["section-heading", "logo-grid"]
    },
    "section-heading": {
      "type": "Text",
      "tag": "p",
      "content": "Powering teams at the world's leading companies",
      "variant": "muted",
      "align": "center"
    },
    "logo-grid": {
      "type": "Grid",
      "columns": 5,
      "gap": 4,
      "children": ["logo-stripe", "logo-shopify", "logo-notion", "logo-linear", "logo-vercel", "logo-github", "logo-figma", "logo-slack", "logo-datadog", "logo-twilio"]
    },
    "logo-stripe": {
      "type": "Surface",
      "variant": "flat",
      "children": ["logo-stripe-text"]
    },
    "logo-stripe-text": {
      "type": "Text",
      "tag": "span",
      "content": "Stripe",
      "weight": "bold",
      "align": "center"
    },
