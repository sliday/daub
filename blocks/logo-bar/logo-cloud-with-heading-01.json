{
  "root": "logo-heading-section",
  "elements": {
    "logo-heading-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 5,
        "align": "center",
        "container": "narrow"
      },
      "children": [
        "heading-group",
        "divider",
        "logo-row"
      ]
    },
    "heading-group": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "trust-badge",
        "main-heading",
        "sub-heading"
      ]
    },
    "trust-badge": {
      "type": "Badge",
      "props": {
        "text": "Trusted Worldwide",
        "variant": "info"
      }
    },
    "main-heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Trusted by 12,000+ teams across 90 countries",
        "weight": "bold",
        "align": "center"
      }
    },
    "sub-heading": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "From Fortune 500 enterprises to fast-growing startups, leading organizations rely on our platform to move faster.",
        "variant": "muted",
        "align": "center"
      }
    },
    "divider": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "logo-row": {
      "type": "Grid",
      "props": {
        "columns": 4,
        "gap": 5
      },
      "children": [
        "logo-spotify",
        "logo-netflix",
        "logo-uber",
        "logo-coinbase",
        "logo-plaid",
        "logo-gitlab",
        "logo-atlassian",
        "logo-hashicorp"
      ]
    },
    "logo-spotify": {
      "type": "Surface",
      "props": {
        "variant": "bordered"
      },
      "children": [
        "text-spotify"
      ]
    },
    "text-spotify": {
      "type": "Text",
      "props": {
        "tag": "span",
        "content": "Spotify",
        "weight": "semibold",
        "align": "center"
      }
    },
    "logo-netflix": {
      "type": "Surface",
      "props": {
        "variant": "bordered"
      },
      "children": [
        "text-netflix"
      ]
