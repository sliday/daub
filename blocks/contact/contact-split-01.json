{
  "root": "contact-split",
  "elements": {
    "contact-split": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 5,
        "container": "wide"
      },
      "children": [
        "section-heading",
        "split-grid"
      ]
    },
    "section-heading": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "title",
        "subtitle"
      ]
    },
    "title": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Contact Us",
        "weight": "bold",
        "align": "center"
      }
    },
    "subtitle": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Reach out through the form or connect with us directly using the details below.",
        "variant": "muted",
        "align": "center"
      }
    },
    "split-grid": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 6
      },
      "children": [
        "form-surface",
        "info-surface"
      ]
    },
    "form-surface": {
      "type": "Surface",
      "props": {
        "variant": "bordered"
      },
      "children": [
        "form-stack"
      ]
    },
    "form-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "form-title",
        "name-field",
        "email-field",
        "phone-field",
        "message-field",
        "send-btn"
      ]
    },
    "form-title": {
      "type": "Text",
      "props": {
        "tag": "h3",
        "content": "Send a Message",
        "weight": "semibold"
      }
    },
    "name-field": {
      "type": "Field",
      "props": {
        "label": "Full Name"
      },
      "children": [
        "name-input"
      ]
    },
    "name-input": {
      "type": "Input",
      "props": {
        "placeholder": "Your full name"
      }
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "you@company.com"
      }
    },
    "phone-field": {
      "type": "Field",
      "props": {
        "label": "Phone (optional)"
      },
      "children": [
        "phone-input"
      ]
    },
    "phone-input": {
      "type": "Input",
      "props": {
        "placeholder": "+1 (555) 000-0000"
      }
    },
    "message-field": {
      "type": "Field",
      "props": {
        "label": "Message"
      },
      "children": [
        "message-input"
      ]
    },
    "message-input": {
      "type": "Textarea",
      "props": {
        "placeholder": "How can we help you?"
      }
    },
    "send-btn": {
      "type": "Button",
      "props": {
        "label": "Send Message",
        "variant": "primary"
      }
    },
    "info-surface": {
      "type": "Surface",
      "props": {
        "variant": "flat"
      },
      "children": [
        "info-stack"
      ]
    },
    "info-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 5
      },
      "children": [
        "info-title",
        "email-info",
        "divider-1",
        "phone-info",
        "divider-2",
        "address-info",
        "divider-3",
        "hours-info"
      ]
    },
    "info-title": {
      "type": "Text",
      "props": {
        "tag": "h3",
        "content": "Contact Information",
        "weight": "semibold"
      }
    },
    "email-info": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "email-label",
        "email-value"
      ]
    },
    "email-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Email",
        "weight": "semibold"
      }
    },
    "email-value": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "hello@acmestudio.com",
        "variant": "muted"
      }
    },
    "divider-1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "phone-info": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "phone-label",
        "phone-value"
      ]
    },
    "phone-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Phone",
        "weight": "semibold"
      }
    },
    "phone-value": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "+1 (415) 555-0198",
        "variant": "muted"
      }
    },
    "divider-2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "address-info": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "address-label",
        "address-value"
      ]
    },
    "address-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Office",
        "weight": "semibold"
      }
    },
    "address-value": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "350 Mission St, Suite 200\nSan Francisco, CA 94105",
        "variant": "muted"
      }
    },
    "divider-3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "hours-info": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "hours-label",
        "hours-value"
      ]
    },
    "hours-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Business Hours",
        "weight": "semibold"
      }
    },
    "hours-value": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Monday - Friday, 9:00 AM - 6:00 PM PST",
        "variant": "muted"
      }
    }
  }
}
