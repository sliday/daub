{
  "root": "contact-with-map",
  "elements": {
    "contact-with-map": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 5,
        "container": "wide"
      },
      "children": [
        "header-group",
        "content-grid"
      ]
    },
    "header-group": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 2,
        "align": "center"
      },
      "children": [
        "heading",
        "subheading"
      ]
    },
    "heading": {
      "type": "Text",
      "props": {
        "tag": "h2",
        "content": "Find Us",
        "weight": "bold",
        "align": "center"
      }
    },
    "subheading": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Visit our office or send us a message — we're always happy to connect.",
        "variant": "muted",
        "align": "center"
      }
    },
    "content-grid": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": 5
      },
      "children": [
        "map-container",
        "form-container"
      ]
    },
    "map-container": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 3
      },
      "children": [
        "map-image",
        "address-row"
      ]
    },
    "map-image": {
      "type": "Image",
      "props": {
        "src": "https://placehold.co/600x400/e2e8f0/475569?text=Map+%E2%80%94+350+Mission+St,+SF",
        "alt": "Map showing office location at 350 Mission Street, San Francisco"
      }
    },
    "address-row": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 4
      },
      "children": [
        "address-block",
        "hours-block"
      ]
    },
    "address-block": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "address-label",
        "address-line-1",
        "address-line-2"
      ]
    },
    "address-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Address",
        "weight": "semibold"
      }
    },
    "address-line-1": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "350 Mission St, Suite 200",
        "variant": "muted"
      }
    },
    "address-line-2": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "San Francisco, CA 94105",
        "variant": "muted"
      }
    },
    "hours-block": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 1
      },
      "children": [
        "hours-label",
        "hours-weekday",
        "hours-weekend"
      ]
    },
    "hours-label": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Hours",
        "weight": "semibold"
      }
    },
    "hours-weekday": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Mon-Fri: 9 AM - 6 PM",
        "variant": "muted"
      }
    },
    "hours-weekend": {
      "type": "Text",
      "props": {
        "tag": "p",
        "content": "Sat-Sun: Closed",
        "variant": "muted"
      }
    },
    "form-container": {
      "type": "Surface",
      "props": {
        "variant": "bordered"
      },
      "children": [
        "form-stack"
      ]
    },
    "form-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": [
        "form-title",
        "name-field",
        "email-field",
        "message-field",
        "submit-btn"
      ]
    },
    "form-title": {
      "type": "Text",
      "props": {
        "tag": "h3",
        "content": "Send Us a Message",
        "weight": "semibold"
      }
    },
    "name-field": {
      "type": "Field",
      "props": {
        "label": "Name"
      },
      "children": [
        "name-input"
      ]
    },
    "name-input": {
      "type": "Input",
      "props": {
        "placeholder": "Your name"
      }
    },
    "email-field": {
      "type": "Field",
      "props": {
        "label": "Email"
      },
      "children": [
        "email-input"
      ]
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "you@example.com"
      }
    },
    "message-field": {
      "type": "Field",
      "props": {
        "label": "Message"
      },
      "children": [
        "message-input"
      ]
    },
    "message-input": {
      "type": "Textarea",
      "props": {
        "placeholder": "What would you like to discuss?"
      }
    },
    "submit-btn": {
      "type": "Button",
      "props": {
        "label": "Send Message",
        "variant": "primary"
      }
    }
  }
}
