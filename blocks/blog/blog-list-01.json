      "direction": "horizontal",
      "gap": 3,
      "align": "center",
      "children": ["bl-thumb-1", "bl-info-1"]
    },
    "bl-thumb-1": {
      "type": "Image",
      "src": "https://picsum.photos/seed/art-edge/240/160",
      "alt": "Edge Computing"
    },
    "bl-info-1": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 1,
      "children": ["bl-cat-1", "bl-title-1", "bl-excerpt-1", "bl-meta-1"]
    },
    "bl-cat-1": {
      "type": "Chip",
      "label": "Infrastructure",
      "variant": "secondary"
    },
    "bl-title-1": {
      "type": "Text",
      "tag": "h4",
      "content": "Why We Moved Everything to the Edge",
      "weight": "bold"
    },
    "bl-excerpt-1": {
      "type": "Text",
      "tag": "p",
      "content": "Our migration from centralized data centers to a globally distributed edge network reduced latency by 73%.",
      "variant": "muted"
    },
    "bl-meta-1": {
      "type": "Text",
      "tag": "p",
      "content": "By Alex Novak · Mar 8, 2026 · 11 min",
      "variant": "muted"
    },
    "bl-sep-1": {
      "type": "Separator",
