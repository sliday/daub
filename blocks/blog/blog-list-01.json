{
  "root": "blog-list",
  "elements": {
    "blog-list": {
      "type": "Stack",
      "direction": "vertical",
      "gap": 4,
      "container": true,
      "children": ["bl-header", "bl-entries"]
    },
    "bl-header": {
      "type": "Text",
      "tag": "h2",
      "content": "Recent Articles",
      "weight": "bold"
    },
    "bl-entries": {
      "type": "Stack",
      "direction": "vertical",
